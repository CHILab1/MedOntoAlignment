  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plain Radiographs of the chest demonstrate a large pleural based mass.Single axial CT image demonstrates a large pleural based mass.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loculated effusion or EmpyemaLipomaFibrous TumorsOther Neoplasm: Peripheral Bronchogenic Carinoma Mesothelioma Liposarcoma Pleural Metastasis (Breast carcinoma, lymphoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fibrous tumor of the pleura</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None at this time.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1904_synpic16150">
  <rdf:type rdf:resource="#CT_Scan"/>
