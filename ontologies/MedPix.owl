<owl:NamedIndividual rdf:about="#case_MPX1389">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1389_synpic42580"/>
  <hasScan rdf:resource="#MPX1389_synpic42582"/>
  <hasPatient rdf:resource="#patient_0114"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Os Acromiale</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">26 year old male with left shoulder pain.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plain radiographs demonstrate a subtle lucency in the acromion. A CT ordered to rule out fracture clearly demonstrates a congentially unfused acromion.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acromion fractureNormal unfused ossification center in patients under 25 yearsOs Acromiale</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Os Acromiale</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT findings and patient age</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treatment choices in symptomatic patients include open acromioplasty or arthroscopic acromioplasty.</treatment_follow_up>
</owl:NamedIndividual>

