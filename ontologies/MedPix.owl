  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Epidermoid Inclusion Cyst</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Facial pain, progressively worse over 6 years</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Numbness over her right face</exam>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vestibular Schwannoma Meningioma Epidermoid inclusion cyst Arachnoid cyst Ependymoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Epidermoid Inclusion Cyst</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pathology</diagnosis_by>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX2272_synpic148">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX2272"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX2272_synpic148.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial T1W MR after Gadolinium.On the left, there is an extraaxial cerebellopontine angle mass without contrast enhancement. This lesion is similar in signal to CSF, but not identical. There also appears to be some internal stucture or signal texture to the mass. The lesion has an undulating or serpentine border with the cerebellum and brainstem. All of these features favor an epidermoid rather than an arachnoid cyst.</caption>
</owl:NamedIndividual>

