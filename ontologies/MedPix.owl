<owl:NamedIndividual rdf:about="#case_MPX1154">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1154_synpic53544"/>
  <hasScan rdf:resource="#MPX1154_synpic53549"/>
  <hasScan rdf:resource="#MPX1154_synpic53543"/>
