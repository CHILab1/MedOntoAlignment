<owl:NamedIndividual rdf:about="#case_MPX1993">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1993_synpic23559"/>
  <hasPatient rdf:resource="#patient_0280"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Small bowel obstruction from inguinal hernia</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">75 year old man presented to emergency room with abdominal pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">WBC normalPhysical exam of the groin area suggested the diagnosis of an inquinal hernia.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plain film: Several dilated stacked loops of small bowel.CT scan of the abdomen and pelvis was performed and demonstrates bowel in the inguinal canal - consistent with hernia.</finding>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Small bowel obstruction from inguinal hernia</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Physical exam and radiological study</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The hernia was manually reduced in the emergency room.Laparoscopic hernia repair was the performed. There was no ischemia of the involved bowel loop.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1993_synpic23559">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1993"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1993_synpic23559.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non contrast CT through the pelvis demonstrates a soft tissue mass within the expected area of the inquinal canal. There may be air within the lumen. From the evaluation of the superior images, this soft tissue mass was confirmed to be bowel.</caption>
</owl:NamedIndividual>

