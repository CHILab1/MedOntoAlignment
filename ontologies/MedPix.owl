  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clinically insignificant hiatal hernia.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">75 yo smoker presents for CT follow-up of pulmonary nodules</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No pertinent exam or laboratory information</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Small Type 1 hiatal hernia (aka axial or sliding hiatal hernia)</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hiatal HerniaParaesophageal Hernia</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clinically insignificant hiatal hernia.</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">One study has shown that up to 7% of patients scanned with CT for Virtual Colonoscopy were found incidentally to have hiatal hernias. (Hellstrom et al 2004)</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treatment not indicated at this time as there are no clinically significant symptoms or complications</treatment_follow_up>
</owl:NamedIndividual>

