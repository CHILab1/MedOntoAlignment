<owl:NamedIndividual rdf:about="#case_MPX2498">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2498_synpic24417"/>
  <hasScan rdf:resource="#MPX2498_synpic24418"/>
  <hasScan rdf:resource="#MPX2498_synpic24419"/>
  <hasScan rdf:resource="#MPX2498_synpic24420"/>
