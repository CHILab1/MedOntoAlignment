<owl:NamedIndividual rdf:about="#case_MPX2488">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2488_synpic24858"/>
  <hasScan rdf:resource="#MPX2488_synpic24859"/>
  <hasScan rdf:resource="#MPX2488_synpic24860"/>
  <hasPatient rdf:resource="#patient_0441"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Silent Sinus Syndrome</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">13 year old with chronic sinusitis, worse for last 3 weeks.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">unremarkable</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Opacified atelectatic left maxillary sinus with infundibular occlusion. Associated nasal septal deviation, enlargement of left middle meatus, retraction of left anterior maxillary sinus wall, and mild retraction of inferior orbital wall.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chronic sinusitisCongenital opacificationSilent SinusPost traumatic deformity</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Silent Sinus Syndrome</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT imaging</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ENT consult, antibiotic therapy and possible surgery.</treatment_follow_up>
</owl:NamedIndividual>

