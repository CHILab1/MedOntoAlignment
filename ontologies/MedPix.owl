<owl:NamedIndividual rdf:about="#case_MPX1213">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1213_synpic10585"/>
  <hasScan rdf:resource="#MPX1213_synpic10586"/>
  <hasScan rdf:resource="#MPX1213_synpic10587"/>
  <hasScan rdf:resource="#MPX1213_synpic10589"/>
  <hasScan rdf:resource="#MPX1213_synpic10590"/>
  <hasScan rdf:resource="#MPX1213_synpic10591"/>
  <hasPatient rdf:resource="#patient_0062"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diffuse cerebral edema - mimic of SAH</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">18 y.o. young woman found down - unconscious for an unknown time and for unknown cause.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comatose</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The sulci and ventricles are not visible. There is high attenuation on the surface of the brain. The suprasellar cistern shows visible CSF - but high attenuation linear material</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Subarachnoid hemorrhage Diffuse cerebral edema Hyperemic brain swelling</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diffuse cerebral edema - mimic of SAH</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging and death certificate (autopsy results not known)</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Despite vigorous resuscitation efforts she died.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1213_synpic10585">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1213"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1213_synpic10585.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">There is diffuse swelling of the brain, very symmetric, with effacement of sulci and ventricles. There appears to be high attenuation on the surface of the brain. This could be due to SAH. However, there is no evidence of blood in the suprasellar cistern.</caption>
</owl:NamedIndividual>

