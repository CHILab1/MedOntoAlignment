<owl:NamedIndividual rdf:about="#case_MPX1746">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1746_synpic51005"/>
  <hasPatient rdf:resource="#patient_0215"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Echinococcal cyst (hydatid disease) of the liver</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Injured in motor vehicle accident with comminuted tibial plateau fracture. Abdomen/pelvis CT imaging included in trauma work-up.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unremarkable abdominal exam.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Incidentally found on CT are two well-defined cysts with thin calcified rim in the posterior right hepatic lobe. Serpentine calcifications are noted within the matrix of one of the cysts.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metastatic CarcinomaHepatic cystadenoma and cystadenocarcinomaPrimary Hepatic TumorEchinococcal CystLiver Abscess</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Echinococcal cyst (hydatid disease) of the liver</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The patients CT findings were consistent with Type V cysts due to the presence of calcifications. In turn, no treatment was indicated because these cysts are considered inactive.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None Indicated</treatment_follow_up>
</owl:NamedIndividual>

