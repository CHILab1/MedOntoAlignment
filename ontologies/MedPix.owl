<owl:NamedIndividual rdf:about="#case_MPX2236">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2236_synpic18692"/>
  <hasScan rdf:resource="#MPX2236_synpic18695"/>
  <hasPatient rdf:resource="#patient_0634"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spongioform Encephalopathy, Presumed variant Creutzfeldt-Jacob Disease</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">25 Y/O with new onset progrssive dementia, myclonus, EEG abnormalities, history of eating raw sheeps brain approximately 2 years ago.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Left frontal lobe biopsy: Spongioform encephalopathy consistent with Creutzfeldt-Jacob disease.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Brain MRI scans approximately 6 months apart show progressive diffuse cortical atrophy, T2/FLAIR and Diffusion increased signal within the Basal Ganglia. Mild increased diffusion signal is seen in the posterior Thalamus (Pulvinar)Correspoding relatively decreased ADC map basal ganglia signal.MR Spectroscopy demonstrated a decrease in NAA peak.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cruetzfeldt-Jacob DiseaseVariant Creutzfeldt-Jacob DiseaseOther transmissible spongioform encephalopathiesDiffuse ischemic insultLess likely:Methanol - putamenCarbon Monoxide - globus pallidus Deposition of iron or copperNeoplastic infiltrationparticularly of lymphoma or glioma.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spongioform Encephalopathy, Presumed variant Creutzfeldt-Jacob Disease</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frontal Lobe Biopsy</diagnosis_by>
</owl:NamedIndividual>

