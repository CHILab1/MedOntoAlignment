<owl:NamedIndividual rdf:about="#case_MPX2008">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2008_synpic27563"/>
  <hasScan rdf:resource="#MPX2008_synpic27564"/>
  <hasPatient rdf:resource="#patient_0608"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avascular Necrosis of the Femoral Heads</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">History of progressive bilateral hip pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frontal radiograph of the pelvis demonstrates central sclerosis of the femoral heads and subtle serpiginous subchondral lucencies.MR images demonstrate low T1 and high T2 signal in a linear subchondral pattern.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avascular necrosis of the femoral heads.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avascular Necrosis of the Femoral Heads</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Characteristic Radiographic and MR imaging.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Please see factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The patient was later treated with intra-articular steroid injections and subsequent surgical core decompression.</treatment_follow_up>
</owl:NamedIndividual>

