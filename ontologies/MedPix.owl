<owl:NamedIndividual rdf:about="#case_MPX1416">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1416_synpic50980"/>
  <hasScan rdf:resource="#MPX1416_synpic50983"/>
  <hasScan rdf:resource="#MPX1416_synpic50984"/>
  <hasPatient rdf:resource="#patient_0124"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Idiopathic Constipation/Retained Stool</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">33 year old woman with constipation since childhood. She presented with abdominal distension and pain.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plain Film: Mottled gas Pattern in the LUQ (large intestine).CT: Markedly abnormal study demonstrating stool-distended bowel extending from the distal transverse colon to the level of the rectum, with associated compression of several structures, most noticeably the distal right ureter with associated mild dilatation of the collecting system. There is also shift of the adnexal structures and uterus to the left. The largest dilatation of the bowel appears to be at the level of the sigmoid colon which measures approximately 11.6cm in short axis diameter.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DDX for Mottled Gas Pattern on Plain film:*Stool*Abscess*Sponge*BezoarDDX for Constipation:*Poor Diet*Poor Bowel Habits*Hirschsprungs Disease*Medications: Iron, antacids, narcotic pain meds...*Laxative abuse*Anal Fissures</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Idiopathic Constipation/Retained Stool</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exclusion of Hirschprungs and Celiac Disease by negative Bx</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient has had biopsies to test for Hirschprungs and Celiac Disease - both of which were negative. She received treatment to clean out her bowel.</treatment_follow_up>
</owl:NamedIndividual>

