<owl:NamedIndividual rdf:about="#case_MPX1325">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1325_synpic22299"/>
  <hasPatient rdf:resource="#patient_0099"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Liver metastases, from bronchogenic carcinoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">69yo M presented to the emergency department with a 4 month history of dull right upper quadrant abdominal pain. He has had a 15 lb weight loss over the last year and admits to a 70 pack year smoking history. The chest CT demonstrated a 1.9 cm speculated mass in the right lower lobe that was the primary tumor.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No abdominal tenderness or jaundice.AST = 102, ALT= 116, ALP= 460, nl bilirubin and INR</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple target appearing masses that have a hyperechoic center with a hypoechoic rim in the left and right lobes of the liverThe ultrasound was followed by a CT that demonstrated multiple low density solid hepatic masses.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Regenerative nodules in cirrhosis, microabcesses, multiple bacterial abscesses, Histoplasmosis, lymphoma, Kaposi sarcoma, multnodular hepatocellular carcinoma, sarcoidosis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Liver metastases, from bronchogenic carcinoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ultrasound and CT, patient declined biopsy</diagnosis_by>
</owl:NamedIndividual>

