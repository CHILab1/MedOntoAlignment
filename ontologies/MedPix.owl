<owl:NamedIndividual rdf:about="#case_MPX2216">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2216_synpic34291"/>
  <hasScan rdf:resource="#MPX2216_synpic34292"/>
  <hasScan rdf:resource="#MPX2216_synpic34293"/>
  <hasScan rdf:resource="#MPX2216_synpic34295"/>
  <hasPatient rdf:resource="#patient_0343"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thyroid Ophthalmopathy</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">45 year old male with known Graves disease referred to ophthamology for proptosis.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-enhanced axial CT image of the orbits demonstrates bilateral proptosis with enlargement of the medial rectus muscle bellies with sparing of the tendonous insertions. Coronal reformatted images demonstrate symmetric bilateral enlargement of the inferior, medial, superior, and to a lesser extent, lateral retus muscles. The retrobulbar fat and globes are unremarkable.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graves OphthalmopathyPseudotumorLymphoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thyroid Ophthalmopathy</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging characterisitcs (involvement of the muscle belly with sparing of the tendinous insertion, bilaterally symmetric) and correlation with the patients known Graves disease.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Please see factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treatment depends upon severity of involvement. When indicated, medical management with steroids and artificial tears to maintain corneal moisture is typically employed.</treatment_follow_up>
</owl:NamedIndividual>

