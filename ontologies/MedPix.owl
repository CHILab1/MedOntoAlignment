<owl:NamedIndividual rdf:about="#case_MPX2094">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2094_synpic31715"/>
  <hasScan rdf:resource="#MPX2094_synpic31716"/>
