<owl:NamedIndividual rdf:about="#case_MPX2199">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2199_synpic15700"/>
  <hasPatient rdf:resource="#patient_0628"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Takayasu Arteritis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">55 year old Asian female with history of polymyalgia rheumatica, presenting with pulseless upper extremities.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diffusely absent or very weak bilateral upper extremity pulses</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Conventional and MR angiography showed multifocal stenosis of the great vessels and branch vessels.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">atherosclerotic disease, giant cell arteritis, fibromuscular dysplasia, idiopathic carotid dissection</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Takayasu Arteritis</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SEE FACTOID</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</treatment_follow_up>
</owl:NamedIndividual>

