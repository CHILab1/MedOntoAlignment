  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Duplicated Inferior Vena Cava</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">55 yo male with gross hematuria.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Within Normal Limits.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The left inferior vena cava extends cephalad as a continuation of the left common iliac vein adjacent to the left side of the aorta, ending in the left renal vein. The normal right IVC extends from the right common iliac vein, following its normal course through the abdomen.</finding>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Duplicated Inferior Vena Cava</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cross Sectional Imaging</diagnosis_by>
</owl:NamedIndividual>

