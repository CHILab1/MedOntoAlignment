<owl:NamedIndividual rdf:about="#case_MPX2460">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2460_synpic17266"/>
  <hasPatient rdf:resource="#patient_0655"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sparsely granulated growth hormone adenoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This 50 year old woman had a several year history of enlarging hands and decreased visual acuity in her right eye.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">She was noted to have coarse facial features with prognathism, skin thickening and very large hands.Visual field examination disclosed a right nasal quadrantanopsia. The neurological examination was otherwise normal.Endocrine studies revealed an elevated baseline growth hormone level and normal prolactin.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fig 1. Coronal CT showing the intrasellar tumor with suprasellar extension. Fig 2. Intraoperative smear prepared from the neoplasm showing sparsely granulated cytoplasm. Also note the occasional intracytoplasmic eosinophilic fibrous bodies, best seen in the very center of the picture.Fig 3. Histological section of the resected neoplasm showing the relatively uniform, sparsely granulated cells. Fig 4. Electron micrograph showing a typical intracytoplasmic body, characteristic of the sparsely granulated growth hormone secreting adenoma.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sella and suprasellar mass: pituitary adenoma pituitary carcinoma or metastasis craniopharyngioma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sparsely granulated growth hormone adenoma</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT disclosed a large intrasellar tumor with suprasellar extension more on the left than the right. Surgery was performed.</treatment_follow_up>
</owl:NamedIndividual>

