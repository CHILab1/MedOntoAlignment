  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myxopapillary Ependymoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">36 year old female with a history of low back pain and mild radicular symptoms.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Noncontributory</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Routine MRI imaging demonstrated and extramedullary intradural ovoid lesion at the L2 level.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Extramedually Intradural lesions (MANDELInS)M: Menigioma/metastaticA: Arachnoid cystN: NeurofibromaD: DermoidE: Epidermoid/EpendymomaL: LipomaIn: Infection (TB, cysticercosis)S: Schwannoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myxopapillary Ependymoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pathology.</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical resection.</treatment_follow_up>
</owl:NamedIndividual>

