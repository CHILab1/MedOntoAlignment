  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1309"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1309_synpic15871.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Patient was scanned prone.Pneumotosis of the ascending colon is likely related to vasculopathy as is the assymetric renal perfusion.</caption>
</owl:NamedIndividual>

