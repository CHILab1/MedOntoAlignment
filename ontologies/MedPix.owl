<owl:NamedIndividual rdf:about="#case_MPX1787">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1787_synpic25265"/>
  <hasScan rdf:resource="#MPX1787_synpic25266"/>
  <hasPatient rdf:resource="#patient_0229"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endobronchial Tumors</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">23 yo male with recurrent hemoptysis.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No findings</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PA and lateral chest films were unremarkable. Lingular bronchial lesion. No associated calcifications. Post obstructive air trapping in lingula.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neoplasm (benign or malignant. Unlikley mucous plug or foreign body given symptomatology.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endobronchial Tumors</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carcinoid diagnosed by bronchoscopy guided biopsy/ resection and histology.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endobronchial lesions: - Tumors 80%, Inflammatory 20% - Less than 10% of tumors are benign Benign: Squamous cell papilloma - most common Hamartomas Pleomorphic adenomaMalignant: Squamous cell carcinoma - most common Adenoid cystic carcinoma Mucoepidermoid carinoma CarccinomaBall valve phenomenon can generate distal air trapping. During exhalation the bronchial caliber decreases. This combined with endobronchial lesion can partially or completely occlude the bronchial lumen generating peripheral air trapping.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lesion resected.</treatment_follow_up>
</owl:NamedIndividual>

