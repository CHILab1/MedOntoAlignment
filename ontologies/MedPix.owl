<owl:NamedIndividual rdf:about="#case_MPX1260">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1260_synpic43421"/>
  <hasScan rdf:resource="#MPX1260_synpic43422"/>
  <hasScan rdf:resource="#MPX1260_synpic43423"/>
  <hasPatient rdf:resource="#patient_0519"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Disruption and tears of the patella tendons bilaterally.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This 42 y/o active duty man jumped from his vehicle and felt a pop. He then tried to hop on the other leg to the aid station and felt a pop in the good leg. The rest is history with him lying in the dirt unable to walk, asking for help, crawling on his belly, etc.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swelling of patellar tendons and high riding patella bilaterally.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plain lateral x-rays of bilateral knees showed patella alta, a high riding patella. Joint effusion was noted. On MRI, disrupted patellar tendons were noted bilaterally.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Trauma due to extreme combat conditions (body armor, heat, stress). Systemic lupus erythematosus Rheumatoid arthritis Steroid use/ abuse</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Disruption and tears of the patella tendons bilaterally.</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plain CR and MRI</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This unusual case may represent how the fog of war may increase incidence of otherwise systemic based injuries.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PT, surgery</treatment_follow_up>
</owl:NamedIndividual>

