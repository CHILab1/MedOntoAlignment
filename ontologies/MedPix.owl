<owl:NamedIndividual rdf:about="#case_MPX1394">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1394_synpic22908"/>
  <hasScan rdf:resource="#MPX1394_synpic22909"/>
  <hasPatient rdf:resource="#patient_0534"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Partial Achilles Tendon tear</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Left ankle/leg pain and weakness</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Weakness on plantar flexion</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plain radiographs demonstrate thickening of the Achilles tendon, convex impression of Achilles tendon on the posterior margin of Kagers fat pad, and a lower limits normal Toygars angle. MR findings demonstrates focal thickening of the Achilles tendon increased T2W signal within the tendon and overlying subcutaneous tissues</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Partial Achilles ruptureComplete Achilles rupture</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Partial Achilles Tendon tear</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging findings were confirmatory</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Conservative treatment, immobilization, followed by physical therapy</treatment_follow_up>
</owl:NamedIndividual>

