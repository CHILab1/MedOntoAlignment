<owl:NamedIndividual rdf:about="#case_MPX2385">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2385_synpic27520"/>
  <hasScan rdf:resource="#MPX2385_synpic27521"/>
  <hasScan rdf:resource="#MPX2385_synpic27522"/>
  <hasScan rdf:resource="#MPX2385_synpic27524"/>
  <hasScan rdf:resource="#MPX2385_synpic27525"/>
  <hasScan rdf:resource="#MPX2385_synpic27526"/>
  <hasPatient rdf:resource="#patient_0407"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">mucus plug</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ICU patient who, after extubation, developed acute onset dyspnea and hypoxia.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/C</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple axial CT images obtained according to the CT pulmonary angiography protocol demonstrates mixed-density (including air density) endoluminal lesion within the bronchus intermedius extending from just past the carina and down, with large areas of atelectasis in the right lower lobe. The air densities strongly suggest that this is a large mucus plug.Oblique coronal reconstructed image shows the extent of this large mucus plug.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">mucus plug</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">mucus plug</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bronchoscopy and aspiration</diagnosis_by>
</owl:NamedIndividual>

