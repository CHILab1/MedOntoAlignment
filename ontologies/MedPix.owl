  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">meniscal ossicle</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">39 year-old male with chronic history of left lateral knee pain and locking.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Within the substance of the posterior horn of the medial meniscus, there are two small lesions which demonstrate a low T1 and T2 signal rim with homogeneous high T1 signal equal to that of marrow fat which demonstrates decrease in signal on fat-saturation images.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">meniscal ossicle</differential_diagnosis>
