  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">benign cystic teratoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient found incidental right adnexal mass during a non-related MR imaging study.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/C</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ultrasound of the pelvis demonstrates a large right adnexal mass with predominantly hyperechoic echotexture. MRI demonstrates a right ovarian cystic mass with predominantly expected homogeneously high T2 signal, with a rind of high T1/T2 signal in the anterior surface which becomes dark on fat-saturation images. This clearly demonstrates the fatty component of what is most likely a benign cystic teratoma.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">benign cystic teratoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">benign cystic teratoma</case_diagnosis>
</owl:NamedIndividual>

