<owl:NamedIndividual rdf:about="#case_MPX1164">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1164_synpic33081"/>
  <hasScan rdf:resource="#MPX1164_synpic33082"/>
  <hasScan rdf:resource="#MPX1164_synpic33084"/>
  <hasPatient rdf:resource="#patient_0047"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral Wilms Tumor</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">10 month old boy, previously healthy, brought to clinic after mom notices a bulge in his abdomen while bathing him.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Right-sided 5x5x8cm echogenic mass in renal fossa exerting mass effect on the right lobe of liver.On CT, left kidney shows 3x2x2cm mass in the interpolar region. Involvement of right renal vein could no be excluded.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">- Wilms Tumor- Neuroblastoma- Polycystic kidney disease- Sarcoma- Hydronephrosis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral Wilms Tumor</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pathological/surgical specimen</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">F/U Ultrasound q 3-6 months to assess for recurrence</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1164_synpic33081">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1164"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1164_synpic33081.png</url>
