  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Oligodendroglioma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">45 year old male with history of persistent headaches.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Post operative noncontrasr CT of the head demonstrates a large mass with ill defined borders that involves the posterior temporal lobe. Chunky calcifications are present. MRI reveals vasogenic edema in the region of the lesion.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Differential diagnosis of temporal lobe lesions:gangliogliomaastrocytomaoligodendroglioma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Oligodendroglioma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pathology</diagnosis_by>
</owl:NamedIndividual>

