  <hasScan rdf:resource="#MPX1908_synpic57747"/>
  <hasPatient rdf:resource="#patient_0256"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chiari I malformation</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">21 y/o woman who presented to the ER with gradual onset headache for the past 2 weeks.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Negative neurological exam.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low lying cerebellar tonsils with cervical cord syringohydromyelia.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cerebellar tonsillar herniation differential includes: space occupying lesions or mass effect within the posterior fossa and Chiarir II malformation.Syrinx differential includes cord masses.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chiari I malformation</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT and MR (including CSF flow studies)</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Twenty five percent of all Chiari I malformations present with cervical syringohydromyelia. It is important to evaluate the cord upon recognition of low lying or herniated cerebellar tonsils.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neurosurgery consultation for evaluation and possible decompression.</treatment_follow_up>
</owl:NamedIndividual>

