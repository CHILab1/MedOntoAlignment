<owl:NamedIndividual rdf:about="#case_MPX1297">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1297_synpic19924"/>
  <hasPatient rdf:resource="#patient_0093"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Killian-Jamieson Diverticulum</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">55 YO male with symptoms of dysphagia.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NC</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT of the neck demonstrates an air-filled lesion adjacent to the proximal esophagus with a questionable connection between the two lumens. Subsequent evaluation of the hypopharynx and upper esophagus demonstrates a large outpouching from the left side of the cervical esophogus originating just inferior to the cricopharyngeus muscle.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Killian-Jamieson diverticulumZenkers diverticulum</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Killian-Jamieson Diverticulum</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">radiographically</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">none</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1297_synpic19924">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1297"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1297_synpic19924.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial CT of the neck demonstrates an air-filled lesion (white arrow) adjacent to the left side of the proximal esophagus (white arrowhead). There is question of a connection between the two lumens.</caption>
</owl:NamedIndividual>

