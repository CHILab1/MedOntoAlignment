<owl:NamedIndividual rdf:about="#case_MPX1735">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1735_synpic16735"/>
  <hasScan rdf:resource="#MPX1735_synpic16737"/>
  <hasScan rdf:resource="#MPX1735_synpic16738"/>
  <hasScan rdf:resource="#MPX1735_synpic16739"/>
  <hasPatient rdf:resource="#patient_0214"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1. Myasthenia Gravis2. Chronic immunosuppression3. S/P Total Thymectomy via median sternotomy</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This is a 22 y/o AD WF at NNMC where she has been followed by Neurology for one year for myasthenia gravis, treated with prednisone and cyclosporin. She has good strength. Chest CT in July 2002 shows residual thymus, and no mass. Now s/p total thymectomy via median sternotomy. Path specimen revealed thymic hyperplasia without malignancy.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Physical exam finding significant for left ptosis and bilateral sluggish papillary reflexes.Path Specimen: Thymic Hyperplasia</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Residual Thymus</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thymic Hyperplasia vs. Thymic atrophyThymomaMalignancy</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1. Myasthenia Gravis
2. Chronic immunosuppression
3. S/P Total Thymectomy via median sternotomy</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.Long-term immunosuppression with prednisone and cyclosprorin2.Total thymectomy3.Recommend pneumonia vaccine 4.May consider adding pyridostigmine for worsening symptoms5.Long-term outpatient care with neurology6.Provide patient education; ensure that she knows danger signs of her disease</treatment_follow_up>
</owl:NamedIndividual>

