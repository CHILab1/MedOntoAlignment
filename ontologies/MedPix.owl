<owl:NamedIndividual rdf:about="#case_MPX1009">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1009_synpic46283"/>
  <hasScan rdf:resource="#MPX1009_synpic46295"/>
  <hasPatient rdf:resource="#patient_0001"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bladder Diverticulum</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">73-year-old male with hematuria and numerous white blood cells found on UA</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bladder with thickened wall and diverticulum on the right. Diverticulum is mostly likely secondary to chronic outflow obstruction.Prostate enlargement.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bladder Diverticulum</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bladder Diverticulum</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</diagnosis_by>
</owl:NamedIndividual>

