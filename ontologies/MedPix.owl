<owl:NamedIndividual rdf:about="#case_MPX1506">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1506_synpic37594"/>
  <hasPatient rdf:resource="#patient_0148"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fracture dislocation at thoraco-lumbar junction, resulting in spinal cord transection.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">8 year old boy in MVA. Patient was in back seat wearing seatbelt.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Paraplegia Multiple extremity injuries</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT:- Fracture dislocation of spine at T12/L1 MRI:- (Post-reduction) Spinal cord transection with intraaxial hemorrhage and spinal cord edema</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fracture dislocation at thoraco-lumbar junction, resulting in spinal cord transection.</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT and MRI</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This young boy was wearing a seatbelt across his lap without using the shoulder component.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Open reduction with fusion of spine</treatment_follow_up>
</owl:NamedIndividual>

