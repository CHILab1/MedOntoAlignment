<owl:NamedIndividual rdf:about="#case_MPX1417">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1417_synpic24443"/>
  <hasScan rdf:resource="#MPX1417_synpic24444"/>
  <hasScan rdf:resource="#MPX1417_synpic24445"/>
  <hasScan rdf:resource="#MPX1417_synpic24446"/>
  <hasPatient rdf:resource="#patient_0540"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemorrhage in Basal Ganglia, Hypertensive, Acute Stroke</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">76 year-old hypertensive male with altered mental status, presenting to the emergency department via EMS.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypertension</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT demonstrates focal high density in the region of the left putamen. Contrast was administered due to apparent vasogenic edema on the preceding non-contrast examination. A follow-up MRI performed 3 months later demonstrates evidence of residual blood products in the same region. Note the decrease in mass effect on the follow-up study.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypertensive hemorrhageAmyloid angiopathy Hemorrhagic primary or metastatic malignancy</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemorrhage in Basal Ganglia, Hypertensive, Acute Stroke</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clinical information supported the diagnosis of hypertensive hemorrhage.</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Medical control of blood pressure.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1417_synpic24443">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX1417"/>
