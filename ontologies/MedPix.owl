<owl:NamedIndividual rdf:about="#case_MPX1947">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1947_synpic16344"/>
  <hasPatient rdf:resource="#patient_0600"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dermoid cyst</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This 3 1/2 year old girl had a midline subcutaneous lumbar mass. The patient complained of tenderness over the lesion but had no problems with bowel or bladder function, or walking.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The patient was described as having intact cranial nerves, normal strength and normal sensation.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1) Oblate spheroid mass in subcutaneous fat of lumbosacral region - distinct from neural structures2)probable tethered cord</finding>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dermoid cyst</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MRI, CT and myelogram showed that the lumbar lesion was not in continuity with the thecal sac. The patient was also thought to have a tethered cord.</discussion>
</owl:NamedIndividual>

