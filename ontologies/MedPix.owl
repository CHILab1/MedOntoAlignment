  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Meningioma of planum sphenoidale</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">39 year-old woman with several month history of bilateral hemianopsia, worse in the morning</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">several month history of bilateral hemianopsia</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Large cicrumscribed midline mass overlying the planum sphenoidale causing cortical buckling of adjacent brain parenchyma. Postcontrast images demonstrate enhancement of the periperipheral portion of the tumor, with a central non-enhancing region.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">metastasisgliomalymphomameningioma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Meningioma of planum sphenoidale</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">surgical resection</diagnosis_by>
</owl:NamedIndividual>

