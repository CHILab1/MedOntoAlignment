  <hasScan rdf:resource="#MPX2319_synpic22073"/>
  <hasPatient rdf:resource="#patient_0383"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">leiomyosarcoma of the inferior vena cava</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient is s/p placement of right ureteral stent for extrinsic obstruction of the right ureter due to a mass demonstrated on previous non-contrast renal stone protocol CT.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unknown, but a patient with this lesion might present with lower extremity edema.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT with intravenous and oral contrast material demonstrates a large retroperitoneal mass with central dystrophic calcifications. This mass is completely separate from the right kidney, which other than the hydronephrosis and the presence of the ureteral stent, is otherwise unremarkable. The liver was also normal.Superior images demonstrate a beak sign with the inferior vena cava and the left renal vein, strongly suggestive of the vascular origin of this tumor.Note the presence of the ureteral stent, and the image demonstrating that the mass has extrinsic mass effect on the course of the ureter, causing the original clinical problem for which this patient was treated.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">leiomyosarcomametastatic disease with tumor thrombusangiosarcomahigh-grade liposarcoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">leiomyosarcoma of the inferior vena cava</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">surgical excision</diagnosis_by>
</owl:NamedIndividual>

