  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">9 y/o boy with dyspnea on exertion. Chest radiograph done a year later (patient at the time had a viral infection) was reported as normal.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unrevealing.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CXR demonstrates a hyperlucent left hemithorax. Follow up CT reveals diminished left lung vasculature and associated decreased parenchymal density.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">P Poland SyndromeO Obstruction (i.e. airway foreign body)E Embolus/EmphysemaM Mastectomy (not applicable in this young male)S Swyer-James Syndrome</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swyer-James Syndrome</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Radiographically</diagnosis_by>
</owl:NamedIndividual>

