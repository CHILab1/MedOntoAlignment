  <hasPatient rdf:resource="#patient_0287"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Staghorn Calculus</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">62 yo male with left flank pain and urinary tract infections.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Coronal MIP noncontrast CT images reveal a staghorn calculus, which forms a cast of nearly the entire left renal collecting system.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Calcifications from granulomatous diseaseCalcified tumorStaghorn Calculus</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Staghorn Calculus</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging findings are diagnostic.</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treatment options for staghorn calculi include percutaneous stone removal, open surgery, or a combination of percutaneous debulking and extracorporeal shockwave lithotripsy (ESWL).</treatment_follow_up>
</owl:NamedIndividual>

