  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Angiomyolipomas in tuberous sclerosis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Follow-up for known history of tuberous sclerosis.</history>
