<owl:NamedIndividual rdf:about="#case_MPX1195">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1195_synpic55737"/>
  <hasScan rdf:resource="#MPX1195_synpic55738"/>
  <hasScan rdf:resource="#MPX1195_synpic55739"/>
  <hasPatient rdf:resource="#patient_0053"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diprosopus (conjoined) twins, Anencephaly</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Young primigravida (G1P0) with uncomplicated pregnancy. Previous US (not known when) reported as no abnormalities. Returns to clinic, and now US fails to show heartbeat.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stillborn baby</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Duplication of facial structures (eyes, teeth) Cleft with partial duplication of vertebrae (L1) Absence of spinal cord and brain Enlarged liver, distorting abdominal and thoracic structures Congenital diaphragmatic hernia (lack of normal lung tissue found on autopsy)</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Conjoined Twins</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diprosopus (conjoined) twins, Anencephaly</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autopsy</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">For discussion, please read the [Topic]</discussion>
</owl:NamedIndividual>

