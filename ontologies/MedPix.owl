  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Centrilobular Emphysema</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">66 y.o. man with a 25 pack/year smoking history</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Apical predominant parenchymal architectural distortion. Pulmonary vessels and bronchioles can be seen in the middle of the lucent bullae, indicating a centrilobular pattern.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Centrilobular EmphysemaPanacinar EmphysemaToxic Chemical ExposureLangerhans cell histiocytosislymphangioleiomyomatosiscystic bronchiectasis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Centrilobular Emphysema</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">http://pathhsw5m54.ucsf.edu/ctpath/ctpath33.html</discussion>
</owl:NamedIndividual>

