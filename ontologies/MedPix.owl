  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cysticercosis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">43 year old man presents with a new onset of seizures.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Normal between seizures.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Solitary ring-enhancing lesion in the right temporal lobe. Thin and smooth rim of enhancement Small chunk of calcification in the lateral/peripheral rim</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abscess - chronic (because of calcification) Neoplasm (astrocytoma, oligodendroglioma)</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cysticercosis</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pathology</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The lesion was resected completely</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1154_synpic53544">
  <rdf:type rdf:resource="#CT_Scan"/>
