  <hasPatient rdf:resource="#patient_0484"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lipomatous hypertrophy of the interatrial septum</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shortness fo breath with concern for pulmonary embolism.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial CT images with intravenous contrast material demonstrate mild smooth thickening of the interatrial septum with diffuse fat attenuation. No pulmonary embolims was present. Note the large amount of subcutaneous fat circumferentially compatible with a large body mass index.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lipomatous hypertrophy of the interatrial septumCardiac lipomaLiposarcoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lipomatous hypertrophy of the interatrial septum</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Please see factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No specific treatment necessary.</treatment_follow_up>
</owl:NamedIndividual>

