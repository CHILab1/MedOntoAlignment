  <isPatientOf rdf:resource="#case_MPX1660"/>
  <age rdf:datatype="http://www.w3.org/2001/XMLSchema#string">74</age>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#case_MPX1665">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1665_synpic54372"/>
  <hasScan rdf:resource="#MPX1665_synpic54373"/>
  <hasScan rdf:resource="#MPX1665_synpic54374"/>
  <hasPatient rdf:resource="#patient_0191"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pancreatic Mucinous Cystic Neoplasm (Mucinous Cystadenoma)</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A 57 yo F with recent gastric bypass surgery developed shortness of breath and tachycardia several days after surgery.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TachycardiaElevated D dimer testOtherwise normal physical exam findings and BMP</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">On CT imaging an incidental 3.6cm mass was seen in the tail of the pancreas. Follow up contrast enhanced CT demonstrated a macrocystic mass in the tail of the pancreas with a coarse calcification. No pancreatic ductal dilation was seen.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1. Mucinous cystic neoplasm (macrocystic cystadenoma)2. Intraductal papillary mucinous neoplasm3. Pseudocyst4. Adenocarcinoma5. Oligocystic variant of a microcystic serous cystadenoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pancreatic Mucinous Cystic Neoplasm (Mucinous Cystadenoma)</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pathology confirmed diagnosis</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During the patients gastric bypass surgery the surgeon noted that the pancreas looked funny. Her pancreatic neoplasm was then later incidentally discovered on CT scan.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical resection was performed because of malignant potential of neoplasm.</treatment_follow_up>
</owl:NamedIndividual>

