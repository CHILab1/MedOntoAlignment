  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal infarct</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">65 year old male presented with flank pain.He had stones several years ago that uneventfully passed.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Initial evaluation for stones was negative. CT through the kidneys was obtain with IV contrast.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT of the kidneys with IV contrast demonstrates large segmental area of non enhancement in the anterior left kidney. There is a very thin rim of enhancement in the outer most cortex which has blood supply from the capsular vascular branches.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">InfarctInfection</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal infarct</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No follow up is available for this patient.</treatment_follow_up>
</owl:NamedIndividual>

