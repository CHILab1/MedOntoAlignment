<owl:NamedIndividual rdf:about="#case_MPX2239">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2239_synpic41018"/>
  <hasScan rdf:resource="#MPX2239_synpic41019"/>
  <hasPatient rdf:resource="#patient_0635"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Choroid Plexus Papilloma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">46 year old woman with history of new onset headaches.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No neurological deficits or seizures.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">T1W gray matter isointense mass in fourth ventricle on T1 MRI.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">choroid plexus papilloma ependymoma subependymoma metastasis to choroid plexus</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Choroid Plexus Papilloma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Resection and pathology confirmation</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Choroid plexus papillomas are most commonly found in the fourth ventricle in adults. This patients tumor location is classic. Hydrocephalus is not seen here but is a common complication of this benign tumor.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Resection with no recurrence of disease.</treatment_follow_up>
</owl:NamedIndividual>

