  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Massive Pulmonary Embolism</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">42 year old active duty female required resuscitation, intubation after an episode of unresponsiveness with no evidence of trauma.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EKG: Right ventricular heart strainHypotension</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Filling defects in both right and left main pulmonary arteries with defects continuing into small arterial branches in peripheral lung fields. Also present is a small right pleural effusion.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Massive Pulmonary Embolism</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient was successfully anticoagulated with warfarin.</treatment_follow_up>
</owl:NamedIndividual>

