<owl:NamedIndividual rdf:about="#case_MPX1420">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1420_synpic19078"/>
  <hasScan rdf:resource="#MPX1420_synpic19079"/>
  <hasScan rdf:resource="#MPX1420_synpic19080"/>
  <hasScan rdf:resource="#MPX1420_synpic19081"/>
  <hasPatient rdf:resource="#patient_0542"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ependymoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A 32 year-old male presented to his primary care provider with unremitting neck pain. He denied any history of trauma. The patient was unresponsive to conservative therapy and plain-film radiographic evaluation was negative. Patient was subsequently referred for a cervical spine MR for further evaluation.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diffuse posterior neck pain w/o any focal tenderness on exam. Patient was neurologically intact.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MRI of the cervical spine and with subsequent CE brain MR demonstrate a lobulated mass within the posterior fossa. The lesion appears to originate in the fourth ventricle and is centered on the midline. The tumor is isointense to gray matter on T1 and mixed iso/hypointense on T2 weighted images. There are scant areas of T1&amp;T2 hypodensity seen which are representative of calcifications or flow voids. There is scattered enhancement with contrast administration.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EpendymomaChoroid Plexus TumorPNETMetastasis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ependymoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgically confirmed.</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The lesion was surgically resected and referred to Radiation-Oncology for XRT therapy.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1420_synpic19078">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX1420"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1420_synpic19078.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sagittal T1WI of the cervical spine demonstrates a multilobulated mass in the inferior aspect of the fourth ventricle. The lesion is isointense to gray matter.</caption>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1420_synpic19079">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX1420"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1420_synpic19079.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sagittal T2WI of the cervical spine demonstrates a multilobulated mass in the inferior aspect of the fourth ventricle. The lesion is of mixed iso/hypointensity when compared to gray matter. There are some small areas of low signal intensity suggestive of calcifications.</caption>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1420_synpic19080">
  <rdf:type rdf:resource="#MRI_Scan"/>
