  <hasScan rdf:resource="#MPX1548_synpic17637"/>
  <hasPatient rdf:resource="#patient_0158"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Iliac vein compression sydrome</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">77 y/o man with right lower quadrant pain</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spongy mass in soft tissue over right lower quadrant</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dimunuitive right common iliac vein with large collateral vessles. No evidence for cirrhosis.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Iliac vein compressionDVTMass effectIatrogenicRadiation</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Iliac vein compression sydrome</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May-Thurner occurs in left common iliac. This case differs because of compression of right common iliac between a large osteophyte and right iliac artery.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Long standing collaterals are present relieving congestion. Anticoagulation.</treatment_follow_up>
</owl:NamedIndividual>

