<owl:NamedIndividual rdf:about="#case_MPX2570">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2570_synpic18865"/>
  <hasScan rdf:resource="#MPX2570_synpic18867"/>
  <hasPatient rdf:resource="#patient_0469"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spigelian hernia</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">54 y/o female with acute abdominal pain and a history of remote abdominal surgery, evaluate for adhesion/obstruction.Plain abdominal film showed possible obstruction</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial, coronal MIP, sagittal, and adjusted coronal plane images reveal bowel herniation through a right lateral abdominal wall defect, near the level of the iliac spines. Oral contrast opacifies minimally dilated bowel to the point of prolapse, beyond which the prolapsed segment and remaining distal bowel are unopacified. There is prolapsed omental fat as well, with mild inflammatory stranding.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spigelian hernia, congenital or acquired</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spigelian hernia</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">see factoid</discussion>
</owl:NamedIndividual>

