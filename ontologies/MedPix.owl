<owl:NamedIndividual rdf:about="#case_MPX1220">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1220_synpic29028"/>
  <hasScan rdf:resource="#MPX1220_synpic29029"/>
  <hasScan rdf:resource="#MPX1220_synpic29030"/>
  <hasScan rdf:resource="#MPX1220_synpic29031"/>
  <hasScan rdf:resource="#MPX1220_synpic29032"/>
  <hasScan rdf:resource="#MPX1220_synpic29033"/>
  <hasScan rdf:resource="#MPX1220_synpic29034"/>
  <hasPatient rdf:resource="#patient_0517"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemangioblastoma (WHO Grade I)</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">26 year-old male with a history of a right posterior fossa mass.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aggressive cystic mass lesion in the right aspect of the posterior fossa measuring 4.8 cm by 3.1 cm by 2.3 cm with a solid enhancing mural nodule measuring approximately 2.1 cm in diameter. There is mild to moderate surrounding edema and flow voids are present within the mural nodule.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HemangioblastomaAstrocytomaMetastasisAbscess</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hemangioblastoma (WHO Grade I)</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pathology proven.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Please see factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical resection.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1220_synpic29028">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX1220"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1220_synpic29028.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aggressive cystic mass lesion in the right aspect of the posterior fossa measuring 4.8 cm by 3.1 cm by 2.3 cm with a solid enhancing mural nodule measuring approximately 2.1 cm in diameter. There is mild to moderate surrounding edema and flow voids are present within the mural nodule.T1 pre-gadolinium: cystic lesion with mural nodule isointense to grey matter signal with a cystic component that is low signal intensity.</caption>
</owl:NamedIndividual>

