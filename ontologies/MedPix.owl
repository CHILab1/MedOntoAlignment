  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Septo-Optic Dysplasia</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">10 year-old male with a known dignosis of septo-optic dysplasia.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An axial T2 image through the mid brain demonstrates absence of the septum pellucidum. Coronal T2 images also demonstrate absence of the septum pellucidum as well as hypoplasia of the optic tracts, chiasm and optic nerves. No other abnormalities were present.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Septo-optic dysplasia</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Septo-Optic Dysplasia</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Brain MRI</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Please see factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</treatment_follow_up>
</owl:NamedIndividual>

