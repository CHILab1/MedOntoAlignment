<owl:NamedIndividual rdf:about="#MPX1754_synpic51423">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX1754"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1754_synpic51423.png</url>
