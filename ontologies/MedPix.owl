<owl:NamedIndividual rdf:about="#case_MPX2233">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2233_synpic17324"/>
  <hasPatient rdf:resource="#patient_0348"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Congenital Lobar Emphysema- Radiographic findings</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2wk old male with respiratory distress</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Progressive respiratory distress/tachypnea/ cyanosis/ wheezing/ decreased breath sounds on left</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hyperlucent lobe(s)- with oligemiaIncreased lobar opacity (rare) in newborn due to retained fetal lung fluid Compression atelectasis of adjacent parenchyma Contralateral mediastinal shift</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pneumothorax Atelectasis with compensatory hyperinflation Pneumatocele Cyst Diaphragmatic hernia Cystic adenomatoid malformation Foreign body</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Congenital Lobar Emphysema- Radiographic findings</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The appropriate treatment of CLE in newborns with respiratory distress is surgical resection of the affected lobe. Conservative management is reasonable in infants who have no or minimal symptoms.This case was treated with surgical resection.</treatment_follow_up>
</owl:NamedIndividual>

