</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1754_synpic51426">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX1754"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1754_synpic51426.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Early subacute hemorrhage involving the left thalamus and basal ganglia extending into the third and both lateral ventricles with mild associated midline shift. Hypointense signal on this T2 image is consistent with intracellular deoxy-Hb state of hematoma in an early hemorrhage. NOTE: Conversion of oxyHb to deoxyHb - that is paramagnetic - takes about 6-12 hours. http://www.star-program.com/upload/abstracts/star_abstracts_287_BRADLEY_HEMORRHAGE.pdf</caption>
</owl:NamedIndividual>

