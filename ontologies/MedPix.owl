<owl:NamedIndividual rdf:about="#case_MPX1084">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1084_synpic21716"/>
  <hasScan rdf:resource="#MPX1084_synpic21717"/>
  <hasScan rdf:resource="#MPX1084_synpic21720"/>
