<owl:NamedIndividual rdf:about="#case_MPX1229">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1229_synpic22020"/>
  <hasPatient rdf:resource="#patient_0059"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Annular Pancreas</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">6 yo girl with multiple year history of early satiety and borderline normal weight gain. History of 25lb weight loss after viral illness.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">UGI demonstrated severe focal narrowing of the second portion of the duodenum with medial displacement of the second portion of the duodenum. CT retrospectively demonstrated a thin segment of pancreatic tissue encircling the second portion of the duodenum.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DDx for duodenal narrowing:Annular pancreasDuodenal webPost-bulbar ulcerDuodenal adenocarcinomaLymphomaExtrinsic compression</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Annular Pancreas</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgery</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical excision of second portion of duodenum with duodenoduodenal anastomosis.</treatment_follow_up>
</owl:NamedIndividual>

