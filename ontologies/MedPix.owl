<owl:NamedIndividual rdf:about="#case_MPX1152">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1152_synpic20557"/>
  <hasPatient rdf:resource="#patient_0039"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sarcoidosis.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">34 year old female presents to the emergency room with abdominal pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PE: Mild bilateral flank pain.Labs: Elevated serum calcium.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1. Lungs with reticulonodular interstitial pattern.2. Nephrolithiasis.3. Diffuse lymphadenopathy.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tuberculosis Lymphoma - almost never shows the striking symmetry Carcinoma (metastatic) Sarcoid Fungal disease</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sarcoidosis.</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Retroperitoneal lymph node CT-guided biopsy.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The patient presented with abdominal pain secondary to bilateral nephrolithiasis.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">To Follow.</treatment_follow_up>
</owl:NamedIndividual>

