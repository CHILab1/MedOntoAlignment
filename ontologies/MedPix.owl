<owl:NamedIndividual rdf:about="#case_MPX2201">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2201_synpic39416"/>
  <hasScan rdf:resource="#MPX2201_synpic39417"/>
  <hasPatient rdf:resource="#patient_0341"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Enostosis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">24 year old male with ulnar sided left elbow pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frontal and lateral radiographs of the left elbow demonstrate normal alignment and joint spaces. Negative for fracture. At the intracondylar portion of the distal humeral metaphysis there is a non-aggressive sub-1 cm sclerotic focus within the medullary cavity. There is no osseous expansion, periosteal reaction or associated soft tissue mass. Multiplanar non-contrast CT images of the distal humerus show that the sclerotic focus has tiny spicules projecting outward to the surrounding medullary cavity.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EnostosisSclerotic metastatic focus</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Enostosis</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Classic imaging characteristic</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Please see factiod.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None required</treatment_follow_up>
</owl:NamedIndividual>

