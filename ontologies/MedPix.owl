<owl:NamedIndividual rdf:about="#case_MPX1199">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1199_synpic33608"/>
  <hasScan rdf:resource="#MPX1199_synpic33610"/>
  <hasPatient rdf:resource="#patient_0514"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carbon Monoxide Poisoning</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">23 year old man with headache and lethargy after an ice storm. Because of a power outage, he has been running a generator in his garage.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral cherry red macula</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral symmetric lesions of abnormal signal intensity in the medial lenticular nuclei (globus pallidus)</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carbon Monoxide Poisoning Methanol intoxication Hypotension</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carbon Monoxide Poisoning</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">History and Imaging findings</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CO binds to Hgb 240X stronger than O2 making carboxyhemoglobinTypical Sx: HA, Lethargy, weakness, dizziness, nausea, and SOB TX is to displace CO with O2 T1/2 is 320 min on room air, 80 min on 100% O2, 23 min at 3atm 100% O2Carbon Monoxide - https://www.youtube.com/watch?v=f3VYQsUGJ00http://bmj.bmjjournals.com/cgi/content/full/319/7217/1082http://www.wfubmc.edu/AirCare/co.htmhttp://jama.ama-assn.org/cgi/content/full/294/12/1482http://www.diseasesdatabase.com/result.asp?glngUserChoice=2364&amp;bytRel=2&amp;blnBW=False&amp;strBB=RL&amp;blnClassSort=True</discussion>
</owl:NamedIndividual>

