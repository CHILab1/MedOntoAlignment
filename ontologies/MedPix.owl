<owl:NamedIndividual rdf:about="#case_MPX1435">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1435_synpic25189"/>
  <hasScan rdf:resource="#MPX1435_synpic25190"/>
  <hasPatient rdf:resource="#patient_0541"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Developmental Venous Anomaly (Venous Angioma)</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Right facial pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Noncontributory</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Large left-sided venous vascular anomaly with the roentgen classic head of snakes (i.e., Medusa Head) configuration. There is a minimal amount of surrounding gliosis.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Venous AngiomaArteriovenous Malformation</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Developmental Venous Anomaly (Venous Angioma)</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Roentgen classic MR diagnosis.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This MR finding represents the classic Medusa Head configuration. These lesions are typically asymptomatic, and the patients symptoms are likely unrelated.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</treatment_follow_up>
</owl:NamedIndividual>

