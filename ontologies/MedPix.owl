  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aberrant Right Subclavian Artery</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">54 year-old female with acute onset chest pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT examination of the chest performed with IV contrast according to a PE/DVT protocol demonstrated an aberrant right subclavian artery. The mediastinum was otherwise unremarkable. There was no pulmonary embolism detected.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aberrant right subclavian artery</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aberrant Right Subclavian Artery</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Characteristic appearance on a Contrast enhanced CT of the chest</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None needed.</treatment_follow_up>
</owl:NamedIndividual>

