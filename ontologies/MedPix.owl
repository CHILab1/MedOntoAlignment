<owl:NamedIndividual rdf:about="#case_MPX1920">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1920_synpic18742"/>
  <hasPatient rdf:resource="#patient_0257"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Boerhaaves syndrome</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">85 year old woman reported vomiting several times after eating, probably secondary to food poisoning. While retching she experienced sudden severe pain in her mid chest and began to vomit blood.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CXR shows left-sided pleural effusion. CT confirms left sided pleural effusion and also shows bubbly pneumomediastinum. UGI shows small perforation on left side of distal esophagus near the GE junction. There is spasm of the esophagus probably as a result of the perforation. There is also a large amount of aspirated contrast material.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Esophageal perforation from ingested foreign object, infection, neoplasm, or instrumentation.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Boerhaave's syndrome</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The diagnosis was confirmed by surgical repair of the esophageal perforation.</diagnosis_by>
</owl:NamedIndividual>

