  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ameloblastoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">20 year old male with left jaw pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Noncontributory</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Noncontrast CT shows a well-marginated, radiolucent, multiloculated, expansile lesion at the left mandibular angle. The lesion abuts but does not destroy several posterior molar teeth.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AmeloblastomaOdontogentic KeratocystCentral Giant Cell GranulomaResidual CystCemento-osseous DysplasiaFollicular CystMyxomaHemorrhagic/Traumatic Bone Cyst</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ameloblastoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biopsy</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exploration, enucleation, and curettage of biopsy-proven ameloblastoma in the left posterior mandible.</treatment_follow_up>
</owl:NamedIndividual>

