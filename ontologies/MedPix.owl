<owl:NamedIndividual rdf:about="#case_MPX1381">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1381_synpic17620"/>
  <hasScan rdf:resource="#MPX1381_synpic17621"/>
  <hasScan rdf:resource="#MPX1381_synpic17622"/>
  <hasScan rdf:resource="#MPX1381_synpic17623"/>
  <hasPatient rdf:resource="#patient_0113"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cholangiocarcinoma - radiographic appearance and biopsy</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">84 year old white male with vague RUQ abdominal pain and elevated CA 19-9 marker.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">RUQ Tenderness. CA 19-9: 514 (0-36) AST: 32 ALT: 53 Alk Phos: 118 Amylase: 56 Lipase: 129 AFP 6.6 (0-10) DEA 3.0 (0-3.4)</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4x4cm hepatic mass with necrotic centerboth early and delayed enhancementassociated left portal vein thrombosis and left hepatic lobe atrophy.Ultrasound images of biopsy of heterogeneous liver mass.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CholangiocarcinomaHepatocellular carcinomaAbscessMetastatic neoplasm</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cholangiocarcinoma - radiographic appearance and biopsy</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-resectable due to comorbidities.The only chance for cure is complete resection. Palliative care consists of ERCP or PCT stenting to relieve obstruction, possible chemo with 5FU and radioablation. Pain control with possible celiac plexus block.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">US guided biopsy reported as moderately differentiated adenocarcinoma.Unfortunately, this lesion is non-resectable due to other coexisting disease. The only chance for cure is complete resection.</treatment_follow_up>
</owl:NamedIndividual>

