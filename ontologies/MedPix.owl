<owl:NamedIndividual rdf:about="#case_MPX2428">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2428_synpic46470"/>
  <hasScan rdf:resource="#MPX2428_synpic46471"/>
  <hasScan rdf:resource="#MPX2428_synpic46472"/>
  <hasScan rdf:resource="#MPX2428_synpic46473"/>
  <hasScan rdf:resource="#MPX2428_synpic46474"/>
  <hasScan rdf:resource="#MPX2428_synpic46475"/>
  <hasScan rdf:resource="#MPX2428_synpic46476"/>
  <hasScan rdf:resource="#MPX2428_synpic46477"/>
  <hasScan rdf:resource="#MPX2428_synpic46478"/>
  <hasScan rdf:resource="#MPX2428_synpic46479"/>
  <hasScan rdf:resource="#MPX2428_synpic46480"/>
  <hasScan rdf:resource="#MPX2428_synpic46481"/>
  <hasPatient rdf:resource="#patient_0653"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intradural Extramedullary Meningioma.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">56 yo male with 24 month history of gradually worsening upper back pain.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An intradural extramedullary mass is seen at the T2 level measuring 1.2 cm AP x 1.1 cm transverse x 1.7 cm craniocaudad. This mass causes mild compression and leftward shift of the spinal cord. Subtle hyperintense T2 signal abnormality is noted within the mass, and uniformly enhances following gadolinium DTPA. There is a no dural tail. The spinal cord is normal in signal. No neural foraminal extension is seen.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intradural Extramedullary Neoplasms:SchwannomaNeurofibromaGanglioneuromaMeningiomaEpidermoidDermoidMetastasis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intradural Extramedullary Meningioma.</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Histologic evaluation confirmed an intradural extramedullary meningioma.</diagnosis_by>
</owl:NamedIndividual>

