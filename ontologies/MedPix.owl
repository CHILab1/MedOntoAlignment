  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sarcoid</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">36 year-old Caucasian man with worsening shortness of breath, exercise intolerance and fatigue. Referred to pulmonary for evaluation.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CXR and CT demonstrate nodular interstitial lung disease with multiple superimposed pulmonary masses/nodules. Significant mediastinal and hilar lymphadenopathy are seen. Numerous splenic and renal nodules are also present.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SarcoidLymphomaLymphangitic Carcinomatosis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sarcoid</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biopsy confirmed.</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unavailable.</treatment_follow_up>
</owl:NamedIndividual>

