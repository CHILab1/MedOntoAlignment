<owl:NamedIndividual rdf:about="#case_MPX1791">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1791_synpic21757"/>
  <hasScan rdf:resource="#MPX1791_synpic21758"/>
  <hasScan rdf:resource="#MPX1791_synpic21759"/>
  <hasPatient rdf:resource="#patient_0581"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lipoma Arborescens</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">presents with atraumatic knee swelling</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">swollen knee</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">There are numerous villous-like projections within the joint space of the knee on MR imaging. These are fatty in signal intensity. There is an associated effusion.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">essentially none.Other synovial processes; such as PVNS, synovial hemangioma and synovial osteochondromatosis; would not present with an arborizing fatty mass.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lipoma Arborescens</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pathognomonic</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This uncommon diagnosis has an Aunt Minnie appearance. The villous-like fatty synovial mass can only be lipoma arborescens</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">surgical excision</treatment_follow_up>
</owl:NamedIndividual>

