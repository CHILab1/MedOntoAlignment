  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2229_synpic28529"/>
  <hasScan rdf:resource="#MPX2229_synpic28530"/>
  <hasScan rdf:resource="#MPX2229_synpic28531"/>
