<owl:NamedIndividual rdf:about="#case_MPX1986">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1986_synpic26293"/>
  <hasPatient rdf:resource="#patient_0277"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nephrolithiasis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Right upper quadrant pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ultrasound of the RUQ demonstrated a normal liver, common duct, and gall bladder. The right kidney deomstrated mild hydronephrosis, hyperemia, mild perinephric fluid, and an enlarged dilated ureter.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nephrolithiasis with obstructing stonePyelonephritisDistal ureter obstruction secondary to a mass</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nephrolithiasis</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-contrast CT of the abdomen/pelvis demonstrating a right-sided stone at the UVJ.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">See Factoid</discussion>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1986_synpic26293">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1986"/>
