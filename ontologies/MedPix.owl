<owl:NamedIndividual rdf:about="#case_MPX2284">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2284_synpic23330"/>
  <hasScan rdf:resource="#MPX2284_synpic23331"/>
  <hasPatient rdf:resource="#patient_0366"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Craniosynostosis; Idiopathic Scaphocephaly</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">9 month old male with premature closure of anterior fontanelle.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frontal bossing. Subtle ridge palpated at midline skull.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hull shaped skull with increased anterior-posterior length relative to width. Bony ridge at sagittal suture. Bifrontal bossing with bitemporal narrowing.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Idiopathic Scaphocephaly Hyperthyroidism Rickets Hyperparathyroidism Underlying genetic disorder (Aperts Syndrome, Crouzons Syndrome, Pfeiffers Syndrome)</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Craniosynostosis; Idiopathic Scaphocephaly</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clinically / Radiographically</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">See discussion.</treatment_follow_up>
</owl:NamedIndividual>

