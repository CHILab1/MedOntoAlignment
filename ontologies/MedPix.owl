<owl:NamedIndividual rdf:about="#case_MPX1852">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1852_synpic29134"/>
  <hasPatient rdf:resource="#patient_0241"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Interstitial Lung Disease</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">63 yo male with hx of dermatomyositis c/o increased SOB</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary - Bilbasilar rhonci, increased SOBCBC - 5.2/13.8/40.9/241BMP - 145/3.4/104/31/13/1.0/87CK - 104</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary fibrosis in a bibasilar pattern. Characterisitc honeycomb pattern commonly seen in interstitial lung disease.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dermatomyositis Other Connective Tissue DiseaseAsbestosRadiationMedication Side Effect</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Interstitial Lung Disease</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Radiographically</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Interstitial lung disease is seen in approximately 10% of cases of dermatomyositis.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High dose prednisone 1 mg/kgMethotrexate</treatment_follow_up>
</owl:NamedIndividual>

