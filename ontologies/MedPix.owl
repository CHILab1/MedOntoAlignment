<owl:NamedIndividual rdf:about="#case_MPX2141">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2141_synpic24031"/>
  <hasScan rdf:resource="#MPX2141_synpic24032"/>
  <hasPatient rdf:resource="#patient_0623"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Epidural Lipomatosis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">76 y.o. man presents with back pain and hyperreflexia in the lower extremities. MRI of brain showed no focal abnormalities.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">+3 hyperreflexia of the lower extremities</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MRI of the spine demonstrates proliferation of the dorsal epidural fat associated with complete effacement of the dorsal sub arachnoid space from the T3 - T9 levels which results in moderate central canal stenosis mild ventral cord flattening at the T6-7 level. There is also multilevel disk disease.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">epidural lipomatosis epidural spread of liposarcoma extradural lipoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Epidural Lipomatosis</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MRI imaging</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The cause for this specific case of epidural lipomatosis is currently unknown. This man is not obease nor does he currently have a diagnosed endocrinopathy. Additionally, he does not take steriods for some underlying condition.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient is currently being treated conservatively with pain meds as needed.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX2141_synpic24031">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX2141"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX2141_synpic24031.png</url>
