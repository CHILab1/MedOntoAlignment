<owl:NamedIndividual rdf:about="#case_MPX2458">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2458_synpic24148"/>
  <hasPatient rdf:resource="#patient_0430"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Small Bowel Lymphoma - diffuse large B cell</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">48 year old male presents with LUQ pain and nausea for the past 4 months.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">nl physical exam and nl labs</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Digital Fluroscopic images demonstrate persistent separation of small bowel loops in the LUQ that are only minimally mobile with compression.CT of the abdomen demonstrates sig mesenteric adenopathy in a bed of fatty mesenteric panniculus and aneurismal dilitation of the small bowelCT/PET scan of the abd and pelvis demonstrates sig increase in uptake in the small bowel and mesentery indicating diffuse involvement. Rounded areas of sparing corresponsing to low density on CT are likely areas of necrosis.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">InfectionIschemiaEdemaNeoplasm - lymphoma - adenocarcinoma - metastatic disease</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Small Bowel Lymphoma - diffuse large B cell</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tissue biopsy</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This case represents a good example of small bowel lymphoma and the modalities used to explore this disease.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient was treated with CHOP+Rituxan and is awaiting bone marrow transplant.</treatment_follow_up>
</owl:NamedIndividual>

