  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PRIMARY CHOLESTEATOMA</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">14 y/o male with intermittent otorrhea of right ear and right TM perforation.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Right TM perforation</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Soft tissue opacity is present in the right middle ear within the epi- and mesotympanum, extending into the mastoid air cells. The right TM is perforated. The ossicles and tegmen are intact. However, the scutum is blunted.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Otitis MediaCholesterol GranulomaCongenital Cholesteatoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PRIMARY CHOLESTEATOMA</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgery</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Right mastoidectomy and tympanoplasty</treatment_follow_up>
</owl:NamedIndividual>

