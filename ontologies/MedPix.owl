  <hasScan rdf:resource="#MPX2498_synpic24423"/>
  <hasPatient rdf:resource="#patient_0446"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Right aortic arch with aberrant left subclavian artery</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vomiting 4 days prior, now with cough and chest pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Initial PA/Lateral images of the chest show a right sided aortic arch without other focal abnormality. CT confirms a right sided arch with aberrant left subclavian artery. Of note is a very prominent diverticulum at the origin of the aberrant left SCA.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Right arch versus Double aortic arch. Mirror image branching vs. aberrant left subclavian artery.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Right aortic arch with aberrant left subclavian artery</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT scan</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Asymptomatic patient with relatively common anomaly of aortic arch. No further follow up needed.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</treatment_follow_up>
</owl:NamedIndividual>

