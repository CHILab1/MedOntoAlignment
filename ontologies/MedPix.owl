<owl:NamedIndividual rdf:about="#case_MPX2461">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2461_synpic37573"/>
  <hasPatient rdf:resource="#patient_0429"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pneumoscrotum</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">55 year man status-post a 10 foot fall</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Scrotal crepitance</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pnsuemoscrotum (air in scrotal sac) is present, as well as diffuse subcutaneous emphysema extending along the patients entire left side. Numerous left-sided rib fractures, left-sided pneumothorax and chest tube are present (not shown).</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pneumoscrotum as a result of: Trauma Pneumothorax Chest tube insertion Fourniers gangrene Recent Surgery</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pneumoscrotum</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">imaging</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Trauma patient with extensive subcutaneous emphysema, likely the result from 6 broken ribs on the left with a left pneumothorax and chest tube.Fournier Gangrene at eMedicine - http://www.emedicine.com/emerg/topic929.htm</discussion>
</owl:NamedIndividual>

