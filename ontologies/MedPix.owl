  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eccentric nodular mass in the left side of the rectum, no local invasion, stranding, or lymphadenopathy. No metastases to liver.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sessile PolypStoolChronic DiverticulitisStromal cell TumorCarcinoidLymphoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Colorectal adenocarcinoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biopsy</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT was performed for staging. Patient is a Dukes B1 stage and underwent successful resection of the tumor.</treatment_follow_up>
</owl:NamedIndividual>

