  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1531"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1531_synpic16441.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial CT scan through the middle portion of the lesion shows mineralized matrix. The attenuation of the lesion is greater than that of marrow fat and less than that of skeletal muscle. CT shows mild expansile remodeling.</caption>
</owl:NamedIndividual>

