<owl:NamedIndividual rdf:about="#case_MPX1095">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1095_synpic18844"/>
  <hasScan rdf:resource="#MPX1095_synpic19689"/>
  <hasScan rdf:resource="#MPX1095_synpic19690"/>
  <hasScan rdf:resource="#MPX1095_synpic19691"/>
  <hasPatient rdf:resource="#patient_0498"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pontine Glioma probably astrocytoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache and CNN palsy</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">I wish I could say papilledema, but we could not get a good fundoscopic.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">expansile lesion of the pons, without contrast enhancement</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pontine Astrocytoma:Diffuse type, WHO Grade 2,3, or 4Pilocytic type, WHO Grade 1</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pontine Glioma probably astrocytoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging appearance - no histology yet</diagnosis_by>
</owl:NamedIndividual>

