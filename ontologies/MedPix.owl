  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Desmoplastic infantile Astrocytoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">9 mo old girl with a history of trauma. A screening CT scan revealed a possible left hemisphere bleed. MRI and skeletal survey were ordered.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non contributory</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT- Mixed density lesion within the posterior temporal and parietal lobes.MRI-Exophytic appearing lesion which has an intra axial component and enhances homogeneously.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MeningiomaPXAMetastatic diseaseAVM</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Desmoplastic infantile Astrocytoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgery and Pathologic examination</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgery only</treatment_follow_up>
</owl:NamedIndividual>

