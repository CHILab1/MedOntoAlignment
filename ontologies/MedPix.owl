  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This axial CT image shows a thickened terminal ileum bowel wall with proximal dilated fluid-filled small bowel loops.</caption>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#patient_0111">
  <rdf:type rdf:resource="#Patient"/>
