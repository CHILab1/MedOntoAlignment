  <hasPatient rdf:resource="#patient_0450"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Crossed fused ectopia</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">72 Y/O MALE with hematuria.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">RBCs noted on UA.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">There is a lobular contour to the single right kidney with separate collecting systems which fuse proximally with congenital megaureter present distally.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Crossed fused ectopia</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Crossed fused renal ectopia is a congenital anomaly which is normally asymptomatic. It does however, place the patient at greater risk in the event of injury to the single kidney. In this case, the CT demonstrates the anomaly but does not reveal the etiology of the patients hematuria.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Congenital variant.</treatment_follow_up>
</owl:NamedIndividual>

