<owl:NamedIndividual rdf:about="#case_MPX1699">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1699_synpic53462"/>
  <hasScan rdf:resource="#MPX1699_synpic53463"/>
  <hasScan rdf:resource="#MPX1699_synpic53464"/>
  <hasScan rdf:resource="#MPX1699_synpic53465"/>
  <hasPatient rdf:resource="#patient_0205"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metastatic Squamous Cell Carcinoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">52 yo woman presented with headaches and mental status changes. Hx of L breast SCCa three years ago treated at that time with lumpectomy &amp; chemoradiotherapy.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilobed cystic appearing right hemispheric mass, with a thin peripheral rim of enhancement.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abscess Parasitic disease Ganglioglioma, Pleomorphic Xanthoastrocytoma (PXA) Metastasis (unusual appearance)</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metastatic Squamous Cell Carcinoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biopsy and Histology</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Squamous cell carcinoma is an uncommon form of breast cancer. In addition, SCCa from any source is an infrequent CNS metastasis. However, metastatic SCCa often forms large necrotic deposits in lung and elsewhere.</discussion>
</owl:NamedIndividual>

