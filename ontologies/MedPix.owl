<owl:NamedIndividual rdf:about="#case_MPX1568">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1568_synpic21206"/>
  <hasScan rdf:resource="#MPX1568_synpic21208"/>
  <hasPatient rdf:resource="#patient_0168"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sarcoidosis, Abdomen and Liver</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient with history of thoracic sarcoid presenting with increasing LFTs and pruritis.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Evidence of hepatomegaly on physical examination but no palpable focal abdominal mass. Labs notable for nonspecifically and mildly elevated LFTs.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Enlarged liver with nodular and heterogeneous pattern of enhancement. Periportal and retroperitoneal lymphadenopathy. These findings are consistent with abdominal sarcoid in this clinical setting.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metastatic Disease (colon, stonach, pancreas, breast, lung)LymphomaOther Infiltrative Liver Processes</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sarcoidosis, Abdomen and Liver</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biopsy proven</diagnosis_by>
</owl:NamedIndividual>

