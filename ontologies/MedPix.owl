  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endometrioma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Young woman with chronic cyclical pelvic pain</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ultrasound shows a mass replacing the right ovary with diffuse homogenous low-level echoes. MRI demonstrates this mass to be high intensity on T1 weighted images and heterogenous low signal intensity on T2 weighted images.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ultrasound differential diagnosis: hemorrhagic cyst, dermoid cyst and mucinous cystadenoma or cystadenocarcinoma of the ovary, or other ovarian neoplasm.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endometrioma</case_diagnosis>
</owl:NamedIndividual>

