<owl:NamedIndividual rdf:about="#case_MPX1733">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1733_synpic55195"/>
  <hasScan rdf:resource="#MPX1733_synpic55196"/>
  <hasPatient rdf:resource="#patient_0576"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vestibular Schwannoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">24 y/o woman with hearing loss and ringing in the left ear</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4x4x5mm soft tissue mass lesion located in the left internal auditory canal.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acoustic neuroma (vestibular Schwannoma) Meningioma Epidermoid inclusion cyst Lipoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vestibular Schwannoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clinical presentation and radiological interpretation</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">She recvd gamma knife irradiation. However, since gamma-knife radiation was ineffective, surgery to remove the extra-axial mass would be the next option.</treatment_follow_up>
</owl:NamedIndividual>

