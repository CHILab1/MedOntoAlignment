<owl:NamedIndividual rdf:about="#case_MPX1520">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1520_synpic19417"/>
  <hasPatient rdf:resource="#patient_0152"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mucinous Cystadenoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">53 year old male noted to have a 2 cm cecal mass on screening colonoscopy.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Asymptomatic</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Well circumscribed 3 cm low attenuation mass in cecum originating from the appendiceal orifice.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chronic appendicits; Mucinous cystadenoma; Mucinous Cystadenocarcinoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mucinous Cystadenoma</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mucin accumulation within the appendix is most commonly secondary to a mucin secreting neoplasm, mucinous cystadenoma or cystadenocarcinoma. Rarely, chronic appendiceal obstruction may result in mucin accumulation.</treatment_follow_up>
</owl:NamedIndividual>

