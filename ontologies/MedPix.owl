  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contrast enhanced axial CT through the level of the pancreatic head demonstrates an aggressive appearing mass with associated biliary obstruction.</caption>
</owl:NamedIndividual>

