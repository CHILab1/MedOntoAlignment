<owl:NamedIndividual rdf:about="#case_MPX1646">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1646_synpic17395"/>
  <hasScan rdf:resource="#MPX1646_synpic17397"/>
  <hasScan rdf:resource="#MPX1646_synpic17398"/>
  <hasPatient rdf:resource="#patient_0185"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical storage of craniotomy fragment pending definitive management</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GSW from global war on terrorism. Evacuated to CONUS for definitive management after stabilization in Germany.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral medial frontal lobe lesions.Bone in anterior abdominal wall.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ACA ischemia-Surgical-Heterotopic ossification-Myositis ossificans</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical storage of craniotomy fragment pending definitive management</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical history</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The ACA territory infarcts may be the result of subfalcial herniation causing compression of the artery against the free margin of the falx. The herniation could have occurred from the bullet shock-wave and/or subsequent brain swelling.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical storage of craniotomy fragment pending definitive management</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1646_synpic17395">
