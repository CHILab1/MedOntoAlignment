<owl:NamedIndividual rdf:about="#case_MPX1515">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1515_synpic16277"/>
  <hasScan rdf:resource="#MPX1515_synpic16278"/>
  <hasPatient rdf:resource="#patient_0550"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spinal meningioma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">50 year old woman with neck pain</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial post-gadolinium T1W images of the cervical spine demonstrated a homogenously enhancing mass that displaces the spinal cord to the right. T2W images of the cervical spine demonstrated an extramedullary-intradural ovoid, isointense mass.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MANDELINS: M(meningioma, mets), A (arachnoid cyst), N (neurofibroma), D (dermoid cyst), E (epidermoid, ependymoma), L (lipoma), IN (infection), S (schwannoma)</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spinal meningioma</case_diagnosis>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1515_synpic16277">
