<owl:NamedIndividual rdf:about="#case_MPX1770">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1770_synpic23443"/>
  <hasPatient rdf:resource="#patient_0225"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Battered child syndrome. Chronic bilateral subdural hematomas.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">5 month old female brought to ER with lethargy. Imaging request stated hypoglycemia.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-contrast CT demonstrated bilateral subdural fluid collections</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-accidental trauma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Battered child syndrome. Chronic bilateral subdural hematomas.</case_diagnosis>
</owl:NamedIndividual>

