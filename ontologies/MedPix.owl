<owl:NamedIndividual rdf:about="#case_MPX1427">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1427_synpic17014"/>
  <hasPatient rdf:resource="#patient_0141"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Choledocholithiasis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">82 year old female examined for vague abdominal pain.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">There is focal areas of increased density in the gallbladder and common bile duct. There is dilation of the pancreatic duct, intra and extrahepatic biliary ducts.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">choledocolithiasis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Choledocholithiasis</case_diagnosis>
</owl:NamedIndividual>

