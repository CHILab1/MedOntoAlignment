  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">meniscal tear</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">26 y.o. male injuried in weekend football game</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple sagittal MR sequence images demonstrate a tear of the medial meniscus with a displaced fragment in the intercondylar notch, in the classic double PCL sign, suggestive of a bucket handle tear.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bucket handle tear of medial meniscus</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">meniscal tear</case_diagnosis>
</owl:NamedIndividual>

