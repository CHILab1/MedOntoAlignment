<owl:NamedIndividual rdf:about="#case_MPX1045">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1045_synpic46886"/>
  <hasScan rdf:resource="#MPX1045_synpic46887"/>
  <hasPatient rdf:resource="#patient_0010"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Horseshoe kidney</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">78 year old man with new onset of painless hematuria. There is no significant past medical history.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">UA - hematuria</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parenchymal bridge (isthmus) connecting the inferior poles of both kidneys = Horseshoe kidneys Complete duplication of the right ureter. a 0.7 x 0.3 cm fat containing lesion in the inferior pole of the left kidney. Multiple tiny calcifications bilaterally. 1.3cm cyst in the anterior aspect of the left kidney, containing a small calcification on its edge.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Horseshoe kidney Right Ureter duplication Angiomyolipoma Nonobstructing stones Renal Cyst</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Horseshoe kidney</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging configuration</diagnosis_by>
</owl:NamedIndividual>

