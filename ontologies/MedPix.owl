<owl:NamedIndividual rdf:about="#case_MPX1272">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1272_synpic26877"/>
  <hasScan rdf:resource="#MPX1272_synpic26878"/>
  <hasScan rdf:resource="#MPX1272_synpic26879"/>
  <hasScan rdf:resource="#MPX1272_synpic26880"/>
  <hasScan rdf:resource="#MPX1272_synpic26881"/>
  <hasPatient rdf:resource="#patient_0078"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adrenal Myelolipoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">83 year old male presents with hematuria PMHx: NIDDM, HTN, HLP, COPD, skin cancer, stroke, macular degeneration, and mycosis fungoidesPSHx: Left hip replacement, appendectomy, laparotomy, intestinal blockade repair</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient noted to have a 3X3cm right adrenal mass with with a large fatty component and small focal areas of calcification.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adrenal MyelolipomaAdrenal Adenoma Adrenal Carcinoma Angiomyolipoma, Kidney Lipoma/Liposarcoma, Soft Tissue</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adrenal Myelolipoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Appearance on CT scan</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lesion was found incidentally on this patient undergoing CT with stone protocol to determine the presence of a possible renal or ureteral mass. Stones were present on imaging in addition to adrenal myelipoma.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clinical montioring. Follow up if symptomatic.</treatment_follow_up>
</owl:NamedIndividual>

