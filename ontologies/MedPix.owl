<owl:NamedIndividual rdf:about="#case_MPX1322">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1322_synpic45731"/>
  <hasScan rdf:resource="#MPX1322_synpic45732"/>
  <hasScan rdf:resource="#MPX1322_synpic45734"/>
  <hasPatient rdf:resource="#patient_0095"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary Embolus</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">76 yo female presents with respiratory distress.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contrast enhanced CT images from a PE/DVT CT protocol reveal large intraluminal filling defects in the right and left main pulmonary arteries. Notice the enlarged main pulmonary artery.</finding>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary Embolus</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging findings are diagnostic.</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The patient was admitted to the hospital and continued to deteriorate clinically. A bedside echocardiogram demonstrated right-sided heart failure. Interventional radiology was consulted, and catheter directed thrombolysis was attempted. Shortly thereafter in the medical intensive care unit, the patient went into pulseless electrical activity (PEA) and shortly expired after unsuccessful cardiopulmonary resuscitation.</treatment_follow_up>
</owl:NamedIndividual>

