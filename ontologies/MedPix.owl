<owl:NamedIndividual rdf:about="#case_MPX1139">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1139_synpic18560"/>
  <hasScan rdf:resource="#MPX1139_synpic18561"/>
  <hasPatient rdf:resource="#patient_0035"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Incidental Malrotation and Acute Appendicitis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">67 year old male presents to the ED with acute onset of lower abdominal pain associated with fever, nausea and vomiting.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rebound tenderness with palpation of abdomen and associated guarding.Fever 103 FWBC 17,000</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contrast enhanced axial CT images of the abdomen demonstrates the presence of a whirlpool sign - inversion of the superior mesenteric vessels - all of the small bowel loops on the right, left-sided colon, and inflamatory changes within the appendix consistent with phlegmon.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MalrotationDiverticulitisAcute AppendicitisMesenteric AdenitisInfectious EnteritisAtypical cholecystitis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Incidental Malrotation and Acute Appendicitis</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT imaging and surgical removal of inflamed appendix.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This is a case of acute appendicitis in an adult with incidental malrotation of the midgut.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient underwent an uneventful appendectomy. A Ladds procedure was not performed given symptoms were believed to be primarily the result of the acute appendicitis and not due to malrotation.</treatment_follow_up>
</owl:NamedIndividual>

