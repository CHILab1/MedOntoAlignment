  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fibrous tumor of the pleura</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">71 yo male with a 100 pack yr smoking history with chest mass found on routine physical exam.</history>
