<owl:NamedIndividual rdf:about="#case_MPX2563">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2563_synpic41792"/>
  <hasScan rdf:resource="#MPX2563_synpic41793"/>
  <hasScan rdf:resource="#MPX2563_synpic41794"/>
  <hasScan rdf:resource="#MPX2563_synpic41795"/>
