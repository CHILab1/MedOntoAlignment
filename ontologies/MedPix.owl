  <hasScan rdf:resource="#MPX1108_synpic16232"/>
  <hasPatient rdf:resource="#patient_0026"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">vertebra plana</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">39 y/o non-smoking female presenting with back pain for two months. No history of fever or weight loss.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">-CT/MRI: There is vertebra plana of L5, with edema and enhancement of the remaining marrow into the posterior elements. There is displacement of the thecal sac posteriorly by the extruded bony fragments.-RADIOGRAPH/CT:Left upper lobe lung mass with numerous bilateral pulmonary nodules, consistent with metastatic disease.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">-Multiple myeloma-Metastatic disease-Langerhans cell histiocytosis -Lymphoma, leukemia-Trauma-Infection</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">vertebra plana</case_diagnosis>
</owl:NamedIndividual>

