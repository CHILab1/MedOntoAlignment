<owl:NamedIndividual rdf:about="#case_MPX2269">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2269_synpic17845"/>
  <hasScan rdf:resource="#MPX2269_synpic17846"/>
  <hasPatient rdf:resource="#patient_0358"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Single Kidney - Renal Agenesis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">51 year old female with a history of left breast carcinoma presents for bone scan to evaluate for metastatic disease.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Status post left mastectomy.Unremarkable blood chemistry and CBC.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bone scan demonstrates no osteoblastic metastatic disease. The right kidney is not visualized. A CT scan demonstrates absence of the right kidney, but the right adrenal gland is intact and normal in appearance. The patient reports no history of right nephrectomy.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal agenesis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Single Kidney - Renal Agenesis</case_diagnosis>
</owl:NamedIndividual>

