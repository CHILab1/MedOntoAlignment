<owl:NamedIndividual rdf:about="#case_MPX1386">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1386_synpic38159"/>
  <hasScan rdf:resource="#MPX1386_synpic38161"/>
  <hasPatient rdf:resource="#patient_0106"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Orbit blow-out fracture</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">51 y/o male with trauma to face.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Facial edema.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">inferior orbit fracture soft tissue swelling bleeding into maxillary sinus</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Given the history, there is no other differential in this case. The soft tissue swelling, fluid in the maxillary sinus, and trap-door appearance of the inferior orbital wall are the classic appearance of an inferior orbital wall blow out fracture.Other etiologies of disruption of the inferior orbital wall would include neoplasm, resection, and aggressive infection.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Orbit "blow-out" fracture</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT</diagnosis_by>
</owl:NamedIndividual>

