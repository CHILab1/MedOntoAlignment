  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HSV Encephalitis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">21 y/o soldier deployed to Iraq. Found down in barracks three days after being treated for non-specific viral illness.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mental status changes, aphasia.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral temporal lobe involvement (LR) with low attenuation on non-contrast CT, enhancement with gadolinium on T1, T2 hyper-intensity and restricted diffusion consistent with edema.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HSV encephalitisVZV encephalitisHHV-6 encephalitisEBV encephalitisvasculitissyphilistuberculous meningitisWNV</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HSV Encephalitis</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PCR for HSV on CSF sample</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The patient received a 14 day course of iv acyclovir. He remained aphasic but otherwise responded well.</treatment_follow_up>
</owl:NamedIndividual>

