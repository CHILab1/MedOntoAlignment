<owl:NamedIndividual rdf:about="#case_MPX2021">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2021_synpic19649"/>
  <hasScan rdf:resource="#MPX2021_synpic19650"/>
  <hasScan rdf:resource="#MPX2021_synpic19651"/>
  <hasScan rdf:resource="#MPX2021_synpic19656"/>
  <hasPatient rdf:resource="#patient_0610"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tethered spinal cord with terminal spinal lipoma.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">17 Year old who at age 10 underwent surgery fo a tethered cord.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Well healed incision. No symptoms of tetherd cord.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lipoma at level L2 and Filum terminale.Cord rotated with fibrous band posteriorly at L2-3.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expected post surgical change versus retethering.Also, atypical dermoid is less likely given the history.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tethered spinal cord with terminal spinal lipoma.</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">surgicall / clinically</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Repositioning the patient prone and supine with breath hold technique on MRI may be considered to distinguish retethering from post-surgical change.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical, if symptomatic.</treatment_follow_up>
</owl:NamedIndividual>

