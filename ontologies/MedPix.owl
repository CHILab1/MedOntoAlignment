<owl:NamedIndividual rdf:about="#case_MPX2604">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2604_synpic49129"/>
  <hasPatient rdf:resource="#patient_0480"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Cell Carcinoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A 55-year-old man complains of blood in his urine.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PE reveals a palpable abdominal mass.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Figure 1. Axial image from a contrast enhanced CT scan shows a heterogenous solid mass within the right kidney.Figure 2. Nephrectomy specimen demonstrates a well-circumscribed mass in the upper pole of the kidney.Figure 3. Histological examination of the mass demonstrates cuboidal cellls intermixed with foam cells in a papillary configuration.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Cell Adenoma Renal Cell Carcinoma Angiomyolipoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Cell Carcinoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pathological examination of nephrectomy specimen</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Computed tomography (Figure 1) confirms a solid mass in the upper pole of the right kidney. Radical nephrectomy was performed and the kidney sent to pathology (Figures 2 and 3).</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Radical nephrectomy</treatment_follow_up>
</owl:NamedIndividual>

