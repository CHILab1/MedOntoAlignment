  <hasPatient rdf:resource="#patient_0548"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ACL Tear with lateral femoral notch sign</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">18 y/o female with history of chronic pain with exercise. No history of specific trauma.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Noncontributory</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Figure 1: Lateral radiograph in an 18 year old female with chronic pain during exercise. Figure 2: Sagital PD shows a low lying ACL consistent with tear. Figure 3: Sagital PD with FS shows an ostoeochondral defect of the lateral femoral condyle corresponding to the radiographic deep lateral femoral notch.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Normal VariantOsteochondral defect, nontraumatic vs traumatic</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ACL Tear with lateral femoral notch sign</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MRI</diagnosis_by>
</owl:NamedIndividual>

