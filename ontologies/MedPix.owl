  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Midgut malrotation with appendicitis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Several week history of poorly localized abdominal pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diffuse lower abdominal pain without rebound or guarding.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Midgut malrotation with duodenum failing to cross midline and small bowel in right abdomen. Cecum in lower mid-right abdomen. Abnormal position of SMV/SMA. Inflammatory changes surrounding cecum and area of appendix with fluid collection.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MalrotationAppendicitis with ruptureAbscessPerforated diverticula</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Midgut malrotation with appendicitis</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">radiographic diagnosis</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Incidental malrotaion. See factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pending</treatment_follow_up>
</owl:NamedIndividual>

