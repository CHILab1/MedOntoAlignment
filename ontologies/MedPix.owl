  <hasPatient rdf:resource="#patient_0532"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Osteochondroma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Twisting injury. Rule out meniscal tear.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No evidence of arthrosis, fracture, avascular necrosis, or bone marrow edema. There is a bony exostosis in the posteromedial aspect of the posterior distal femoral metaphysis with contiguous marrow. The exophytic mass is well defined and measures 2-3mm. It has increased T2 singal. The image and history is consistant with osteochondroma. There is no evidence of meniscal or ligament tears.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">osteochrondromaosteosarcoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Osteochondroma</case_diagnosis>
</owl:NamedIndividual>

