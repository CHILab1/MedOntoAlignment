  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intraosseous Lipoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A 45-year-old female with no significant past medical history presented to the emergency department with a painful knee following a fall from standing height.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tender to palpation over patella.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CR, CT, and MR demonstrate a well-defined lytic lesion in the distal femur with mixed fluid and fat attenuation and scattered calcification.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fibrous Dysplasia, ABC, Hemangioma, Bone Infarct, Chondroid Tumor, Intraosseous Lipoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intraosseous Lipoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">radiographically</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">none</treatment_follow_up>
</owl:NamedIndividual>

