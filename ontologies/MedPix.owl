  <hasScan rdf:resource="#MPX1342_synpic16787"/>
  <hasPatient rdf:resource="#patient_0102"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rabdomyosarcoma, prostate. botryoid subtype</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Urinary obstruction, hematuria. Afebrile w/o history of febrile illness.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Findings: US: lobulated mass at bladder trigone with color flow, with apparent involvement of bilateral ureteral orifices.Mild right pelvocaliectesis . CT: Irregular soft tissue mass posterior bladder wall outlined by contrast instilled through catheterMRI: T2WI shows enlargement of the prostate.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rhabdomyosarcoma, hemangioma, neurofibroma, pheochromocytoma, leiomyoma, focal cystitis, inflammatory pseudotumor, RP abcess (unlikely given history), hematoma (unlikely w/ flow), TCC and Leimyosarcoma (rarely), benign tumors (rarely)</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rabdomyosarcoma, prostate.  botryoid subtype</case_diagnosis>
</owl:NamedIndividual>

