  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pancreatic Divisum</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">45 year old male with recurrent pancreatitis. No history of alcohol use or gallstones.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">amylase - 648</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT abdomen: parallel pancreatic ductsMRCP: Dorsal duct of Santorini tranversely crossing the bile duct to enter the minor papilla.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Persistent duct of Santorini</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pancreatic Divisum</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ERCP</diagnosis_by>
</owl:NamedIndividual>

