<owl:NamedIndividual rdf:about="#case_MPX1063">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1063_synpic22165"/>
  <hasScan rdf:resource="#MPX1063_synpic22166"/>
  <hasScan rdf:resource="#MPX1063_synpic22167"/>
  <hasPatient rdf:resource="#patient_0016"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">thoracic aortic dissection</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">76 year-old woman with long history of hypertension, with acute-onset chest pain.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/C</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple axial CT images of the chest with intravenous contrast material demonstrates a Stanford type A thoracic aortic dissection, with a clear intimal flap separating the true and false lumens of the ascending aorta. Additionally, the pericardium full of dense fluid, likely hemopericardium.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">thoracic aortic dissection</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">thoracic aortic dissection</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">confirmed during surgery</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Despite prompt surgical treatment, the patient did not survive the post-operative course. The patient passed away at post-operative day 3.</treatment_follow_up>
</owl:NamedIndividual>

