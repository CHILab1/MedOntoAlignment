<owl:NamedIndividual rdf:about="#case_MPX1454">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1454_synpic24715"/>
  <hasScan rdf:resource="#MPX1454_synpic24717"/>
  <hasScan rdf:resource="#MPX1454_synpic24718"/>
  <hasScan rdf:resource="#MPX1454_synpic24719"/>
  <hasPatient rdf:resource="#patient_0129"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Von Meyenburg Complex - Multiple biliary hamartomas</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">45 yo female with multiple hepatic, non enhancing lesions seen on CTPA</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shortness of breath prompted CTPA. Normal labs (including LFTs)</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CTPA shows multiple, non enhancing hepatic low density lesions, 4-10 mm.MR further characterizes these lesions as non enhancing, fluid signal lesions.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Numerous hepatic cystsPolycystic liver diseaseHepatic microabscessesMultiple metastasesCholedochal cyst 4-5</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Von Meyenburg Complex - Multiple biliary hamartomas</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging characteristics suggest Von Meyenburg</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Incidence: .15-2.8% of autopsiesEtiology: failure of involution of embryonic bile ductsAssociations: polycystic liver diseaseSymptoms: asymptomaticBile duct hamartoma, aka von Meyenburg complex, is a benign tumor composed of disorganized bile ducts and ductules and fibrocollagenous stroma. Although bile duct hamartoma is benign, there have been reports of an association of cholangiocarcinoma with multiple bile duct hamartomas. Bile duct hamartoma has a nonspecific imaging appearance and can simulate metastases or microabscesses. Therefore, histologic diagnosis is required.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Recommend 3 month follow up to document stability vs tissue biopsy.</treatment_follow_up>
</owl:NamedIndividual>

