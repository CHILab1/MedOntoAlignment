  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple angiomyolipomas, renal cysts, renal cell carcinoma.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Angiomyolipomas in tuberous sclerosis</case_diagnosis>
