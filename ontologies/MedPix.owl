<owl:NamedIndividual rdf:about="#case_MPX1608">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1608_synpic24721"/>
  <hasPatient rdf:resource="#patient_0562"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dilated Virchow Robin Space</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Headache.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non contributory.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Small cystic lesion in the medial left temporal lobe with signal that follows CSF on all sequences.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dilated Virchow Robin Space</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dilated Virchow Robin Space</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging only.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">See factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None.</treatment_follow_up>
</owl:NamedIndividual>

