<owl:NamedIndividual rdf:about="#case_MPX2261">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2261_synpic13155"/>
  <hasPatient rdf:resource="#patient_0637"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple MyelomaDiagnosis was confirmed by biopsy of humeral lesion and bone marrow aspirate.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">60 year old male presents to ortho for evaluation of right upper extremity pain.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The images submitted are all from the same patient within a several month period. These demonstrate the various sensitivies of the imaging modality however are all nonspecific. All confirm a presence of a polyostotic intramedullary process with altered/increased bone metabolism.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple MyelomaMetastatic diseaseLymphomaOsteomyelitis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple Myeloma
Diagnosis was confirmed by biopsy of humeral lesion and bone marrow aspirate.</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient subsequently fractured the proximal humerus which was stabilized with internal fixation.</treatment_follow_up>
</owl:NamedIndividual>

