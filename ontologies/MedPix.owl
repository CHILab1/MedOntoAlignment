<owl:NamedIndividual rdf:about="#case_MPX2603">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2603_synpic15933"/>
  <hasPatient rdf:resource="#patient_0479"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bicornuate Uterus</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">28 year old woman with right lower quadrant abdominal pain.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endometrial fluid, with fluid pattern suggestive of an arcuate uterus, or less likely, partial bicornuate uterus. Small amount of free fluid in the pelvis. Prominent ovaries, with numerous enlarged follicles.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Partial Bicornuate UterusArcuate Uterus</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bicornuate Uterus</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Findings in this case are more consistent with arcuate uterus than bicornuate uterus.</discussion>
</owl:NamedIndividual>

