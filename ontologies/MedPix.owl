<owl:NamedIndividual rdf:about="#case_MPX1538">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1538_synpic41609"/>
  <hasScan rdf:resource="#MPX1538_synpic41611"/>
  <hasScan rdf:resource="#MPX1538_synpic41612"/>
  <hasPatient rdf:resource="#patient_0160"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pneumocystis jiroveci (P. carinii) Pneumonia</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">39 year old male who is HIV positive, with a CD4 count of 71 cells/mm3, and complaint of dyspnea on exertion.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">WBC: 5.2 K/ULLDH: 541 (100-225) U/L</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chest Radiography: Biapical air space opacities are noted with stranding toward the hila. No pleural effusions or adenopathy is evident.Contrast Enhanced CT: Both patchy and confluent air space opacities are evident in a central bilateral upper lobe distribution, with sparing of the lower lung zones. No significant adenopathy is noted.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">M. tuberculosisBacterial PneumoniaPneumocystis jiroveci (carinii)M. avium-intracellulareFungal organisms</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pneumocystis jiroveci (P. carinii) Pneumonia</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BAL was positive for pneumocystis jiroveci.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This case demonstrates atypical radiographic findings of PCP, as the salient abnormalities are air space opacities occurring in a predominately upper lobe distribution. These findings are in stark contrast to the symmetric perihilar and bilateral lower lobe reticular opacities frequently identified in PCP.</discussion>
</owl:NamedIndividual>

