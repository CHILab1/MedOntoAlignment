  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PHEOCHROMOCYTOMA</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypertension, occ palpations, heat intolerance</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">elevated urine vma</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">large left adrenal mass. Location within the adrenal gland excluded adenopathy. Contrast within bowel excluded bowel as an etiology.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PheochromocytomaMetsHemorrhageAdenoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PHEOCHROMOCYTOMA</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical biopsy</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The mass was surgically excised.</treatment_follow_up>
</owl:NamedIndividual>

