<owl:NamedIndividual rdf:about="#MPX1147_synpic27153">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX1147"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1147_synpic27153.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mass lesion evident in axial section in the CPA with ice-cream cone morphology, originating from the ICA. Avid post gadolinium contrast enhancement is evident.</caption>
</owl:NamedIndividual>

