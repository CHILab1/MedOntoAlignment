<owl:NamedIndividual rdf:about="#case_MPX1355">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1355_synpic55466"/>
  <hasPatient rdf:resource="#patient_0120"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nodular Sclerosing Hodgkins Lymphoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A previously healthy 23 y/o woman presents with a 4-month history of itchy skin, night sweats, and a 20-lb unintentional weight loss.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anterior (superior) mediastinal mass, surrounding the great vessels and aortic arch.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mediastinal Mass: Thymoma - Most common 1 anterior mediastinal mass (20%) Lymphoma Germ Cell Tumors Mediastinal Cysts Pericardial, Bronchogenic, Enteric, Thymic Aneurysm of Ascending Aorta Thyroid/Parathyroid Tissue</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nodular Sclerosing Hodgkin’s Lymphoma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pathology</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Signs &amp; SymptomsOften asymptomatic Most common = painless lymphadenopathy1/3 of pts present w/systemic symptomsFatigue, generalized pruritis, B symptoms [low-grade fever, night sweats, weight loss]Mediastinal masses may also produce mass effects SubtypesNodular SclerosingMixed Cellularity Lymphocyte-DepletedLymphocyte-RichNodular Lymphocyte-Predominant Nodular Sclerosing SubtypeMost common subtype in the USAffects females malesMedian age of onset = mid-20s Bimodal peak distribution of onset Young adults (15-35) and late adulthood (55)Associated with EBV and HIVhttp://www.uptodate.com/contents/anterior-mediastinal-mass-lesionshttp://emedicine.medscape.com/article/201886-overview</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Standard treatment: ABVD w/XRTAdriamycin [doxorubicin], Bleomycin, Vinblastine, DacarbazinePrognosis is good, especially for young pts with early-stage disease 5 year survival rate of 90%</treatment_follow_up>
</owl:NamedIndividual>

