  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azygous Lobe</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">45 year old male with recent diagnosis of gastric carcinoma undergoing staging CT.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contrast enhanced axial images (in lung windows) of the upper lungs demonstrates a pleural invagination from the right apex investing the azygous vein.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azygous lobeFocal atelectasis or pleural scarring.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Azygous Lobe</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contrast enhanced CT.</diagnosis_by>
