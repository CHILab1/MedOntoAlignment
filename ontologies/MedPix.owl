<owl:NamedIndividual rdf:about="#case_MPX2595">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2595_synpic51006"/>
  <hasScan rdf:resource="#MPX2595_synpic51007"/>
  <hasPatient rdf:resource="#patient_0478"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Duplicity (duplication)</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">History of blunt trauma to abdomen during motor vehicle accident.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unremarkable exam.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Absence of left kidney sinus incidentally noted on CT abdomen.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intrarenal mass (transitional cell carcinoma)Hypertrophied Column of Bertin</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Duplicity (duplication)</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The patients CT findings were incidental, and the patient had no related symptoms or complaints. In turn, no further work-up or treatment was indicated.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None indicated.</treatment_follow_up>
</owl:NamedIndividual>

