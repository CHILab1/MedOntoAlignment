  <hasScan rdf:resource="#MPX2229_synpic28534"/>
  <hasScan rdf:resource="#MPX2229_synpic28536"/>
  <hasPatient rdf:resource="#patient_0349"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary Sequestration</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">54 year old male with a right lower lobe mass seen on virtual colonoscopy.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-enhanced virtual colonoscopy images demonstrate a soft tissue density mass within the right lower lobe.Intravenous contrast enhanced CT of the chest demonstrates a well-defined mass within the right lower lobe with an arterial supply arising from the abdominal aorta. Lung window images demonstrate no air-filled bronchi within the mass.3D reconstructed image from the Vitrea workstation demonstrates the mass within the right lower lobe adjacent to the right hemi-diaphragm.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary sequestration Necrotizing pneumonia Bronchogenic cyst Diaphragmatic hernia Rounded atelectasis Neurogenic tumor</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary Sequestration</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contrast enhanced CT of the chest with multiplanar reformatation showing the arterial supply from the abdominal aorta</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Please see factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">As the patient was asymptomatic, no treatment was indicated.</treatment_follow_up>
</owl:NamedIndividual>

