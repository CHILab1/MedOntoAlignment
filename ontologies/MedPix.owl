<owl:NamedIndividual rdf:about="#case_MPX1238">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1238_synpic27745"/>
  <hasPatient rdf:resource="#patient_0067"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skull cap in anterior abdominal wall with underlying liquified hematoma.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">26 yo man developed persistent GI symptoms after craniocerebral trauma.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tissue culture negative for bacteria</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skull cap within the left lower anterior abdominal wall. There is a 10x6x1.5 cm nonenhancing fluid collection just posterior to the skull cap.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Liquified Hematoma Abscess Proteinaceous Fluid Collection</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skull cap in anterior abdominal wall with underlying liquified hematoma.</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical history and negative bacterial cultures</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient had a craniectomy for intracranial hypertension. The removed skull cap was placed subcutaneously in his abdominal wall for preservation. There is a companion case:http://rad.usuhs.mil/medpix/medpix.html?mode=pt&amp;pt_id=6414top</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical removal of skull cap from abdomen and cranioplasty using prosthetic plastic material.</treatment_follow_up>
</owl:NamedIndividual>

