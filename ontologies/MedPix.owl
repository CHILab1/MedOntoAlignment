<owl:NamedIndividual rdf:about="#case_MPX1809">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1809_synpic17628"/>
  <hasPatient rdf:resource="#patient_0231"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cervical cancer with bilateral hydronephrosis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">29 y/o G6P5051 female arrived on airevac from micronesia island with history of post-coital bleeding.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">-6 x 6 cm cervical mass with infiltrated surrounding fat, consistent with cervical cancer. -There are several prominent asymmetric pelvic lymph nodes on the left side. These are not pathologic by size criteria, however, in the presence of nearby malignancy these may represent metastatic disease. -There is mild bilateral hydronephrosis from the cervical mass compressing both ureters. Additionally, the image through the kidneys demonstrates delayed nephrogram of the right kidney secondary to higher back pressure of the right hydronephrosis compared with the left.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cervical cancer</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cervical cancer with bilateral hydronephrosis</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral hydronephrosis should always cause concern for cervical cancer in a female patient.</discussion>
</owl:NamedIndividual>

