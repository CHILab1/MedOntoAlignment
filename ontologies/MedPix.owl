<owl:NamedIndividual rdf:about="#case_MPX2002">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2002_synpic57895"/>
  <hasPatient rdf:resource="#patient_0283"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Partial Anomalous Pulmonary Venous Return</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Healthy 5 y.o. girl with a normal birth history</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Harsh systolic ejection murmur at left upper sternal border.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cardiac gated CT: Left sided supracardiac partial anomalous pulmonary venous return with all left pulmonary veins draining into the left innominate vein via a persistent left vertical cardinal vein. The vertical vein is intimate with the left atrial appendage. Right atrium and right ventricle are mild to moderately enlarged.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Partial anomalous pulmonary venous return (PAPVR) Persistent left sided SVC Left superior intercostal vein</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Partial Anomalous Pulmonary Venous Return</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cardiac gated CT correlated with echocardiogram</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient offered elective surgical repair</treatment_follow_up>
</owl:NamedIndividual>

