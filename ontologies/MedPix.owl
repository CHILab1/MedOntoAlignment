  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clot embolusIn situ thrombusTumor embolus</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary Embolism</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging of clot</diagnosis_by>
