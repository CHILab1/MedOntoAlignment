  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">acute infarct</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">36 year-old woman with sudden-onset left-sided hemiparesis. PMH is significant for a history of SLE.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/C</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-contrast CT images of the head with stroke window settings demonstrate a wedge-shaped focal area of decreased density and loss of gray-white matter differentiation at the leve of the right frontal lobe, just anterior to the central sulcus.Diffusion weighted and associated ADC map axial MR images show a corresponding focus of restricted diffusion, consistent with an acute infarct.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">acute infarct</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">acute infarct</case_diagnosis>
</owl:NamedIndividual>

