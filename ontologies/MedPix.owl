<owl:NamedIndividual rdf:about="#case_MPX1596">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1596_synpic20748"/>
  <hasPatient rdf:resource="#patient_0175"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Meningioma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">26 y.o. man complains of headache</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No abnormal findings</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">6 cm extra axial left parietal mass with vasogenic edema</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">meninigioma if extra-axial astrocytoma, oligo-dendroglioma if intra-axial</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Meningioma</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical excision with pathologic confirmation</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This extra axial mass demonstrates a large number of arterial feeders, typical for meningioma.Angiographically, a large stain of contrast is seen with a central focus. This capillary tumor blush arrives early in the arterial phase and stays late into the venous phase. Previously coined the mother-in-law phenomenon, since it comes early, stays late, and usually is very dense.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Resection and re-imaging to insure no recurrence or residual tumor</treatment_follow_up>
</owl:NamedIndividual>

