<owl:NamedIndividual rdf:about="#MPX1303_synpic24511">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX1303"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1303_synpic24511.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Homognenous, hyperintense mass on the T1WI. Note the extension of the mass into the tentorium, extension into the collicular plate, and the anterior displacement of the diencephalon and corpus callosum on the sagittal image. Surprisingly, this mass does not appear to have significantly blocked the aqueduct of Sylvius. The fourth ventricle is normal.</caption>
</owl:NamedIndividual>

