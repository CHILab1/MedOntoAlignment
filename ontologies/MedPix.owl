<owl:NamedIndividual rdf:about="#case_MPX1487">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1487_synpic24425"/>
  <hasPatient rdf:resource="#patient_0144"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lipomas of the small bowel</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sixty-three year-old man with upper abdominal discomfort.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple intraluminal small bowel collections of fat,consistent with lipomas, are demonstrated. The largest measures approximately 3.1 x 1.7 cm, and is located in the third portion of the duodenum.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gastrointestinal lipomas</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lipomas of the small bowel</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT attenuation measurements</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Several gastric lipomas were also identified.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Esophago gastro duodenoscopy (EGD) demonstrated numerous polypoid masses in the duodenum.</treatment_follow_up>
</owl:NamedIndividual>

