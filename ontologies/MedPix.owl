  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acromegaly from pituitary macroadenoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">30 year old man with changing glove and shoe size.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sellar enlargement can be seen on plain radiographs. CT demonstrates sellar expansion with osseous erosion and remodeling. MRI demonstrates an isointese lesion on T1 and T2 images, which expands the sella.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pituitary adenomaCraniopharyngiomaRathke cleft cystPituitary metastasis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acromegaly from pituitary macroadenoma</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical resection.</treatment_follow_up>
</owl:NamedIndividual>

