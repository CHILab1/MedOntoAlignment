  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary arteriovenous malformations in hereditary hemorrhagic telangiectasia.</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">81 year old man with facial telangiectasias, daily epistaxis and decreased blood oxygenation is found to have pulmonary arteriovenous malformation on CT.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary AVM with single feeding artery and single feeding vein</finding>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pulmonary arteriovenous malformations in hereditary hemorrhagic telangiectasia.</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient was treated with coil embolization of the feeding artery to the AVM.</treatment_follow_up>
</owl:NamedIndividual>

