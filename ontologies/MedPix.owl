<owl:NamedIndividual rdf:about="#case_MPX2050">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2050_synpic19947"/>
  <hasPatient rdf:resource="#patient_0299"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eosinophilic granuloma of the calvarium</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Skull pain</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Noncontributory</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mutliple well-defined lytic lesions that coalesce and in an overall geographic appearance. Location is predominatly posterior half of calvarium. Beveled-edge appearance can be seen radiographically.CT show greater destruction of the inner table compared to the outer.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metastatic diseaseOsteomyelitisLymphomaEwings sarcomaEosiniphilic granuloma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eosinophilic granuloma of the calvarium</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biopsy</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Note the atypical greater destruction of inner table relative to outer table, yet still resulting in the classic beveled edge appearance</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</treatment_follow_up>
</owl:NamedIndividual>

