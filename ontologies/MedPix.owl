<owl:NamedIndividual rdf:about="#case_MPX1496">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1496_synpic18546"/>
  <hasPatient rdf:resource="#patient_0146"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fibrous Dysplasia of the Clivus</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">41 year old female with increasing headaches and a family history of aneurysms. A head CT performed at another institution was reportedly unremarkable. MRI/MR angiography of the Circle of Willis was performed at our institution to evaluate for possible aneurysm.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Noncontributory</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The MRI/MRA study showed no vascular pathology, but incidentally it was noted that there was a heterogeneous and mildly expanded clivus.Whole body skeletal scintigraphy showed nonspecific increased uptake in the clivus region.Repeat CT of the sinus was performed, revealing a ground glass appearance, containing a smaller circumscribed area, which has the appearance of a cystic lesion. Overall the process appeared nonaggressive and was stable on 5 month follow-up CT.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chordoma* Chondrosarcoma* Plasmacystoma Lymphoma GCT* Cavernous hemangioma* Carcinomas (adenocystic or nasopharyngeal) Mets* Pagets* should have low T1, high T2 signal</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fibrous Dysplasia of the Clivus</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Presumptive based on characteristic imaging findings.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pending Biopsy/Resection</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1496_synpic18546">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1496"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1496_synpic18546.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fig. 1. Axial noncontrast CT image show a nonaggressive-appearing clivus lesion with a ground glass appearance. There is a sharply-marginated cystic component anteriorly.</caption>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#patient_0146">
  <rdf:type rdf:resource="#Patient"/>
