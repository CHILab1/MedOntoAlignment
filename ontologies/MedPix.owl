  <isScanOf rdf:resource="#case_MPX1515"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1515_synpic16277.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial post-gadolinium T1W image demonstrates a homogenously enhancing mass that displaces the spinal cord to the right. The tumor was surgically proven to be a meningioma.</caption>
</owl:NamedIndividual>

