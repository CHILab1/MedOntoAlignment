  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Cell Carcinoma (clear cell)</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">72 year old female with gross hematuria</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial CT images after intravenous contrast material administration demonstrate an aggressive enhancing heterogenous exophytic mass arising from the upper pole of the left kidney and extending into the left renal vein. The inferior vena cava remains patent. A small ventral hernia is also noted.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal cell carcinomaOncocytomaMetastatic disease</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Renal Cell Carcinoma (clear cell)</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Histology</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Please see factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The patient subsequently underwent left total nephrectomy.</treatment_follow_up>
</owl:NamedIndividual>

