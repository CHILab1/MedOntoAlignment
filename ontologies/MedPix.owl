<owl:NamedIndividual rdf:about="#case_MPX2463">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2463_synpic17001"/>
  <hasScan rdf:resource="#MPX2463_synpic17003"/>
  <hasPatient rdf:resource="#patient_0431"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probable metastatic rhabdomyosarcoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Remote Hx of Bladder Rhabdomyosarcoma. Now with 2months Of Pelvic Pain , Possible Tumor Recurrence s/p Chemo &amp; Xrt 5 Yrs Ago</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Proteinuria</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT: enlargement of the left internal pelvic musculature w/ mild sclerosis of the adjacent acetabulum</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metastatic rhabdomyosarcoma Other sarcoma, ie Ewings hematoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Probable metastatic rhabdomyosarcoma</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metastatic/Recurrent rhabdomyosarcoma is by far the most likely diagnosis in this patient with a history of bladder rhabdomyosarcoma. Less likely considerations would include primary Ewings sarcoma.</discussion>
</owl:NamedIndividual>

