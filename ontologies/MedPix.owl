<owl:NamedIndividual rdf:about="#case_MPX1782">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1782_synpic50939"/>
  <hasScan rdf:resource="#MPX1782_synpic50978"/>
  <hasPatient rdf:resource="#patient_0580"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pseudotumor cerebri</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">39 y/o woman with worsening headaches and blurry vision x 6 weeks.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Obese womanVA:20/125 right eye, 20/125 left eyeIshihara color plate 3/11 right eye, 3/11 left eyeExtraocular movements intactNo Relative afferent pupillary defect Humphrey visual field (30-2): constricted to approx 10 degree OUModerate optic disk edema 360 degrees OU</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased fluid within the optic nerve sheaths Partially empty sella Slight flattening of the posterior aspect of the left globe at the optic nerve insertion</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Idiopathic intracranial hypertension Obstructive hydrocephalus Intracranial mass lesion</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pseudotumor cerebri</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lumbar puncture</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral optic nerve sheath fenestration. Visual acuity improved to 20/40 left eye and 20/40 right eye and color vision returned to 11/11 left eye and 11/11 right eye on ishihara color plates on post-op day 1.</treatment_follow_up>
</owl:NamedIndividual>

