<owl:NamedIndividual rdf:about="#case_MPX1320">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1320_synpic39575"/>
  <hasScan rdf:resource="#MPX1320_synpic40714"/>
  <hasScan rdf:resource="#MPX1320_synpic40715"/>
  <hasPatient rdf:resource="#patient_0524"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral Optic Gliomas</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The patient presented with a history of slowly progressive decreased visual acuity.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased signal intensity and widening of the optic nerves as they track posteriorly.There is a well circumscribed 1.5X1cm mass of high signal intensity located at the location of the optic chiasm. The lesion is suprasellar.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Meningioma Optic glioma SarcoidOptic neuritisMetastasisLymphoma/leukemia</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bilateral Optic Gliomas</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biopsy</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This case is unique in that it is a novel presentation of a lesion overwhelmingly found in children.</discussion>
</owl:NamedIndividual>

