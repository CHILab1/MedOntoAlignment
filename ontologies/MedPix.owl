  <isScanOf rdf:resource="#case_MPX1617"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1617_synpic35941.png</url>
