<owl:NamedIndividual rdf:about="#case_MPX1884">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1884_synpic21850"/>
  <hasScan rdf:resource="#MPX1884_synpic21851"/>
  <hasScan rdf:resource="#MPX1884_synpic21852"/>
  <hasScan rdf:resource="#MPX1884_synpic21853"/>
  <hasScan rdf:resource="#MPX1884_synpic21854"/>
  <hasPatient rdf:resource="#patient_0591"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breast implant, rupture, extracapsular silicone</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">55 Y/O female with bilateral silicone iplants. Has right breast mass to 3-4oclock</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Right breast mass at 3 oclock position of the right breast.</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ultrasound findings- classic linguini sign consisting of hyperechoic linear objects coursing through the implant. Hyperechoic shadowing of all structures, typical of silicon infiltrating into tissues surrounding the implant capsule.MRI- Linguini sign with high signal on h20 saturation in the soft tissue surrounding the implant.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">silicone implant rupture</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Breast implant,  rupture, extracapsular silicone</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">US, MRI</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The findings of this case are classic for bilateral implant rupture, with extravasation of silicone to the tissues adjacent to the capsule. A silicone granuloma has formed.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pt was referred back to the primary provider, for eventual referral to plastic surgery for possible revision.</treatment_follow_up>
</owl:NamedIndividual>

