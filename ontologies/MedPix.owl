<owl:NamedIndividual rdf:about="#MPX1750_synpic18488">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1750"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1750_synpic18488.png</url>
