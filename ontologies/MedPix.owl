<owl:NamedIndividual rdf:about="#case_MPX1711">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1711_synpic18538"/>
  <hasScan rdf:resource="#MPX1711_synpic18539"/>
  <hasScan rdf:resource="#MPX1711_synpic18541"/>
  <hasScan rdf:resource="#MPX1711_synpic18542"/>
  <hasScan rdf:resource="#MPX1711_synpic18543"/>
  <hasPatient rdf:resource="#patient_0209"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Portal Vein Thrombosis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">71 year-old male three months post radio frequency ablation of liver malignancy.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Near occlusive thrombosis is seen in the main portal vein with complete occlusion of the right portal vein, but trace contrast to the left portal vein. There is no evidence of enhancement within the thrombus. These findings suggest a bland thrombus.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Idiopathic, portal vein invasion or compression by tumor, post operative (splenectomy, transplant), blood dyscrasias, coagulopathies, sepsis, pylephlebitis, pancreatitis, cholangitis, suppurative lymphadenitis, cirrhosis, and portal hypertention.</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Portal Vein Thrombosis</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT scan</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Arterial or venous thrombolysis, thrombectomy, or surgical decompression and shunt placement.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1711_synpic18538">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1711"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1711_synpic18538.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT of abdomen with contrast. Near occlusive thrombosis is seen in the main portal vein with complete occlusion of the right portal vein, but trace contrast to the left portal vein. There is no evidence of enhancement within the thrombus. These findings suggest a bland thrombus. Note the large hypodense lesion with enhancing septations in the right lobe of the liver worrisome for progression of hepatic malignancy.</caption>
</owl:NamedIndividual>

