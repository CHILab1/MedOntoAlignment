<owl:NamedIndividual rdf:about="#case_MPX1135">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1135_synpic16704"/>
  <hasScan rdf:resource="#MPX1135_synpic16705"/>
  <hasScan rdf:resource="#MPX1135_synpic16706"/>
  <hasPatient rdf:resource="#patient_0036"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pheochromocytoma</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">30 y/o male with no significant PMH presents with symptoms of headache and flushing. Was discovered to have BP 250/140.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Physical exam unremarkable. Thyroid normal. Lungs clear. Cardiac exam WNL. No abdominal masses. Lan: 24 hr VMA 107.6 (0-10.0), epinephrine 170 (. 5-20), norepinephrine 460 (15-18) total catecholamines 3196 (123-671 supine)</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT Chest Abd Pelvis with oral and IV contrast large soft tissue mass arising from left adrenal gland measuring 9.5 X 8.9 X 13cm in the oblique coronal, AP, and Craniocaudal dimensions. Loss of tissue plane between tail of pancreas, spleen, and bowel.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hyperthyroidism, meduloblastoma, soft tissue sarcoma, incidentaloma, myeloolipoma, renal cell carcinoma, adrenal cortical carcinoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pheochromocytoma</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">prazosin 1mg po BID prior to surgery followed by surgical excision. Follow up with repeat VMA and metanephrines and imaging studies. If the pheochromocytoma is malignant, as evidenced by invasion and metastasis then treatment is primarily surgical with chemotherapy playing only a palliative role.</treatment_follow_up>
</owl:NamedIndividual>

