  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tear of the Achilles tendon- almost complete (Grade II tear)</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">50 y/o WM with left posterior lower leg pain x 2months, made worse with walking/standing.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decreased strength with plantar flexion, + Achilles TTP, Normal previous plain x-ray.</exam>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.Almost complete rupture Achilles tendon- Grade II tear2.Almost complete rupture of Achilles tendon (Grade II tear) with interstitial tear and/or tendinopathy of the proximal Achilles tendon</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tear of the Achilles tendon- almost complete (Grade II tear)</case_diagnosis>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.Ortho Consult2.Immobilization3.NSAIDS4.Physical Therapy</treatment_follow_up>
</owl:NamedIndividual>

