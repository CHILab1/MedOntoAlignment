<owl:NamedIndividual rdf:about="#case_MPX1705">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1705_synpic23363"/>
  <hasPatient rdf:resource="#patient_0206"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pheochromocytoma (Path proven)</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hypertension and episodic headaches, palpitations, and diaphoresis.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">24 hour urine lab values METANEPHRINE. . . . . 4764 ug/L METANEPHRIN 24H . . . 7146 (45-290) ug/24hr NORMETANEPHRINE . . . 3052 ug/L NORMETA 24H . . . . . 4578 (82-500) ug/24hr METANEPH TOT 24 . . 11724 (120-700) ug/24hr EPINEPHRINE 24H . . . 407 (0.5-20.0) ug/24 Hr NOREPINEPHRINE. . . . 422 ug/L NOREPI 24H. . . . . . 633 (15-80) ug/24 Hr CORTSL PT CHA . . . . . 36.2 H (5.0-18.0) ug/dL</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT demonstrates a large left adrenal mass without calcification on the non-contrast CT. The tumor has heterogenous enhancement with central necrotic area.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PheochromocytomaAdrenocortical CarcinomaMetastasisLipid-poor adenoma [on the unenhanced CT (27HU)]</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pheochromocytoma (Path proven)</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elevated urine metanephrines and surgical specimen</diagnosis_by>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Surgical resection of mass</treatment_follow_up>
</owl:NamedIndividual>

