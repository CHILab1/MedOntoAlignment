  <isScanOf rdf:resource="#case_MPX1243"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1243_synpic24671.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cortically based calcification extends toward adjacent myositis ossificans, without medullary contiguity. There is no cortical destruction.</caption>
