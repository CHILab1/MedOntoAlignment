  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">epiploic appendagitis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">27 year old female with acute onset left lower quadrant pain, r/o diverticulitis or appendicitis.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">beta-HCG negativeotherwise N/C</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A small round fatty lesion adjacent to the proximal sigmoid colon outlined by a ring of soft tissue attenuation, plus surrounding stranding of mesenteric fat. There is also a small focal thickening of the adjacent sigmoid colonic wall. No diverticula were noted in the entirity of the sigmoid colon (not shown).</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">epiploic appendagitis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">epiploic appendagitis</case_diagnosis>
</owl:NamedIndividual>

