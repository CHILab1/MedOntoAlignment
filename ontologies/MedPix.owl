  <hasPatient rdf:resource="#patient_0621"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hydroxyapatite deposition disease</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">65 y/o with longstanding right knee pain</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AP radiograph and Proton Density Fat Saturation (PD FS) knee MR from 2002 showing calcific deposits within the lateral collateral ligament (LCL). More recent imaging from 2005 showed resolution of calcium deposits.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hydroxyapatite deposition diseaseCalcium pyrophosphate deposition disease</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hydroxyapatite deposition disease</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Resolution confirms diagnosis</diagnosis_by>
</owl:NamedIndividual>

