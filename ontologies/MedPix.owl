  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">32 year-old male, rule out sinusitis.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ossification of the bilateral stylohyoid ligaments (right greater than left). No significant paranasal sinus disease.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Elongations of the styloid process bilaterallyOssification of the bilateraly stylohyoid ligaments</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Findings consistent with Eagle Syndrome in the proper clinical setting.</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-contrast CT of the paranasal sinuses.</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Please see factoid.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treatment is based upon the presence of symptoms, and includes conservative medical management or surgical removal.</treatment_follow_up>
</owl:NamedIndividual>

