<owl:NamedIndividual rdf:about="#case_MPX2387">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX2387_synpic26379"/>
  <hasPatient rdf:resource="#patient_0406"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Synovial sarcoma-biphasic</title>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">palpable midline mass</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial and reformatted sagittal CT scans of the abdomen after oral and intraveous contrast show a large extraluminal mass with areas of low-attenuation mass with nodularity and large areas of necrosis and hemorrhage. On some images, the mass is adherent to the stomach and displaces surrounding viscera.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Synovial sarcoma, leiomyosarcoma,metastatic disease, malignant fibrous histiocytoma sarcoma, rhabdomyosarcoma, liposarcoma, Burkitt lymphoma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Synovial sarcoma-biphasic</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Biopsy: Immunohistology-biphasic spindle cells admixed with epithelioid cells.Molecular studies-t(X:18) translocation</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unfortunately this patient developed an uncommon soft tissue neoplasm in an atypical location, which progressed despite optimal surgical and medical management.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Marginal excision, radiotherapy, and chemotherpay (doxyrubicin and cyclophosphamide)Patient developed metastases to the liver within 2 years of primary treatment.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX2387_synpic26379">
