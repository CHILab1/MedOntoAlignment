<owl:NamedIndividual rdf:about="#case_MPX1132">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1132_synpic23654"/>
  <hasScan rdf:resource="#MPX1132_synpic23661"/>
  <hasScan rdf:resource="#MPX1132_synpic23663"/>
  <hasPatient rdf:resource="#patient_0502"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adenomyosis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">36 yo female presents with intermenstrual bleeding for several month. The bleeding is now increased in the amount with cramping.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ultrasound demonstrated heterogenous uterus. There were no fibroids. MRI of the pelvis confirmed suspicion of adenomyosis. T2 sequence demonstrates thickening of junctional zone and increased focal signal through out the myometrium.</finding>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adenomyosis</case_diagnosis>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">see factoid</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient underwent transvaginal hysterectomy</treatment_follow_up>
</owl:NamedIndividual>

