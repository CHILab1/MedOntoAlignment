  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Duplicated Renal Collecting System</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">36 year old female with a liver mass.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Triple phase IV contrast study of the abdomen demonstrates a liver hemangioma, and incidental note is made of a left-sided bifid ureter.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Duplicated Renal Collecting System</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CT scan</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">See Factoid</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">N/A</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1950_synpic27241">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1950"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1950_synpic27241.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Three delayed contrast enhanced CT images of the abdomen demonstrating the left kidney with a superior pole and collecting system, a more inferior image of the left kidney with parenchyma and no collecting system (the so-called \faceless\ kidney), and a still more inferior image of the left kidney with the reappearance of a collecting system, consistent with a duplicated collecting system.</caption>
</owl:NamedIndividual>

