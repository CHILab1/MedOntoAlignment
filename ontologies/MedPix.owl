  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Astrocytoma, low-grade, supratentorial</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">43 y/o male who presents with chronic headaches but recently worsened.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Noncontrast head CT demonstrates a large intraaxial mass which appears based in the right parietal lobe then extends into the right lateral ventricle. Some calcification is present. Pathology from a brain biopsy came back as a grade 2 astrocytoma.</finding>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Astrocytoma, low-grade, supratentorial</case_diagnosis>
</owl:NamedIndividual>

