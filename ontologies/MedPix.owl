  <isScanOf rdf:resource="#case_MPX2004"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX2004_synpic24599.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Note the extensive intraaxial vasogenic edema.</caption>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX2004_synpic24600">
  <rdf:type rdf:resource="#MRI_Scan"/>
  <isScanOf rdf:resource="#case_MPX2004"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX2004_synpic24600.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Note the extensive intraaxial vasogenic edema, despite being a low-grade (GR 1) meningioma. The hemispheric swelling from the edema is causing subfalcial and tentorial brain herniation.</caption>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX2004_synpic24601">
