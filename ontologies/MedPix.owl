  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial noncontrast CT image shows a diffusely enlarged liver, with particular prominence of the left lobe. Incidental note is made of a small left renal calculus.</caption>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1568_synpic21208">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1568"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1568_synpic21208.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Axial contrast-enhanced CT image in the early phase shows heterogeneous and somewhat nodular enhancement of the enlarged liver, without discreet hepatic mass. Note the improved visualization of the periportal and retroperitoneal lymphadenopathy with the use of intravenous contrast. The spleen is noted to be surgically absent.</caption>
</owl:NamedIndividual>

