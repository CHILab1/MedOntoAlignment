<owl:NamedIndividual rdf:about="#case_MPX1170">
  <rdf:type rdf:resource="#Case"/>
  <hasScan rdf:resource="#MPX1170_synpic19419"/>
  <hasScan rdf:resource="#MPX1170_synpic19421"/>
  <hasScan rdf:resource="#MPX1170_synpic19422"/>
  <hasScan rdf:resource="#MPX1170_synpic19423"/>
  <hasScan rdf:resource="#MPX1170_synpic19424"/>
  <hasScan rdf:resource="#MPX1170_synpic19425"/>
  <hasScan rdf:resource="#MPX1170_synpic19426"/>
  <hasScan rdf:resource="#MPX1170_synpic19427"/>
  <hasScan rdf:resource="#MPX1170_synpic19428"/>
  <hasPatient rdf:resource="#patient_0058"/>
  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intracerebral hemorrhage (likely related to chronic hypertension)</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">89 y/o with past medical history significant for dementia and hypertension, noted to have altered mental status at home.</history>
  <exam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Admission vitals included BP 165/105 and GCS=4. No evidence of external trauma. Pupils reactive to light but w/ slow response. Breath sounds clear bilat; normal S1 &amp; S2, no m/r/g; abdomen s/nd/nt; radial pulses 2+ bilat; GCS-4 (verbal-1, eyes-1, motor-2)Na-145, K-4.0, Cl-106, CO2-30, BUN-28, Creat-0.8, GLU-109WBC-13.4, Hgb-14.1, Hct-43.1, Plt-383Alk phos-92, AST-32, ALT 35, TBili-0.9</exam>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parenchymal hematoma, right occipital lobeSmall amount of ventricular blood</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vascular malformationHypertensive hemorrhageAmyloid angiopathyMetastatic disease (e.g. renal, lung etc.)Occult trauma</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intracerebral hemorrhage (likely related to chronic hypertension)</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">By exclusion</diagnosis_by>
  <discussion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This patient presented with altered mental status prompting an evaluation for intracranial bleed. Her long history of hypertension is likely the main factor leading to the intracerebral hemorrhage (ICH) noted.</discussion>
  <treatment_follow_up rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient had been admitted to another hospital one week prior and was diagnosed with acute occipital lobe hemorrhage. Right occipital blood collection noted on CT was unchanged from the previous admission. Evaluation for acute change of mental status revealed a urinary tract infection. After antibiotic treatment for UTI, patients GCS improved to 10-12 (pt unable to speak x 3 years).Hospice care was arranged for the patient.</treatment_follow_up>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MPX1170_synpic19419">
  <rdf:type rdf:resource="#CT_Scan"/>
  <isScanOf rdf:resource="#case_MPX1170"/>
  <url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/CHILab1/MedPix-2.0/blob/main/images/MPX1170_synpic19419.png</url>
  <caption rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A single, large intraparenchymal hemorrhage is present within the right occipital lobe measuring 3x2cm with adjacent edema. There is mild mass effect. Blood is also seen within the posterior horn of the right lateral ventricle. A small amount of blood is seen within the posterior falx. The right lateral ventricle is smaller than the left side. The sulci, on the right posterior region, is effaced. The left side appears grossly unremarkable. Minimal opacification of the right sphenioid sinus is present. Mastoids appear well aerated. The rest of the findings appear unremarkable.</caption>
</owl:NamedIndividual>

