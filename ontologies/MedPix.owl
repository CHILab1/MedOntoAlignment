  <title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Osteopoikilosis</title>
  <history rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient 1: 25 yo female with right lower quadrant pain.Patient 2: 35 yo female with left lower quadrant pain.</history>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient 1: AP radiograph of the abdomen reveals multiple 2 3mm punctate ovoid sclerotic foci in the femurs and pelvis, clustered in a periarticular distribution.Patient 2: CT of pelvis demonstrates multiple punctate, oblong sclerotic foci symmetrically distributed throughout the proximal feumurs and pelvis, clustered in a periarticular distribution. No aggressive features are noted.</finding>
  <differential_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Osteopoikilosis Osteoblastic metastases Mastocytosis Tuberous sclerosis</differential_diagnosis>
  <case_diagnosis rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Osteopoikilosis</case_diagnosis>
  <diagnosis_by rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Imaging findings are characteristic.</diagnosis_by>
</owl:NamedIndividual>

